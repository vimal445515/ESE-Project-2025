<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Category UI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
     <link rel="stylesheet" href="/adminStyles/sideBar.css">
    <link rel="stylesheet" href="/adminStyles/navBar.css">
    <style>
       
        :root {
            --primary-color: #4054d2; 
            --bg-color: #f4f6f9; 
            --secondary-bg-color: #eef2ff;
            --border-color: #eee;
        }
        body {
            background-color: var(--bg-color);
            min-height: 100vh;
        }
        .container-fluid {
            padding: 2rem;
        }
        
       
        .top-header {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 1rem 0;
        }
        .user-info {
            display: flex;
            align-items: center;
            font-size: 0.9rem;
            font-weight: 500;
        }
        .user-dot {
            width: 10px;
            height: 10px;
            background-color: #00d084; 
            border-radius: 50%;
            margin-right: 0.5rem;
        }

     
        .thumbnail-card {
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            padding: 1.5rem;
        }
        .image-placeholder-box {
            border: 2px dashed #a5a9d2;
            background-color: #f8f9fa;
            border-radius: 0.5rem;
            padding: 1.5rem;
            text-align: center;
            min-height: 200px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
        }
        .check-icon {
            position: absolute;
            top: 10px;
            right: 10px;
            color: #00d084; 
            font-size: 1.5rem;
        }
        .change-image-btn {
            background-color: var(--secondary-bg-color);
            color: var(--primary-color);
            font-weight: 600;
            border: none;
            padding: 0.5rem 2rem;
            border-radius: 0.3rem;
        }
        <style>
    :root {
        --sidebar-width: 250px;
        --primary-blue: #4054d2; 
        --bg-light: #f5f6fa;
    }

    body { 
        background-color: var(--bg-light); 
        font-family: 'Poppins', sans-serif;
        overflow-x: hidden; 
    }

    
    #page-content-wrapper {
        margin-left: var(--sidebar-width);
        width: calc(100% - var(--sidebar-width));
        min-height: 100vh;
        transition: margin .25s ease-out;
    }

    #sidebar-wrapper {
        min-height: 100vh;
        width: var(--sidebar-width);
        position: fixed; 
        left: 0;
        z-index: 1000;
        transition: margin .25s ease-out;
    }

   
    .content-body {
        padding: 20px;
        width: 100%;
    }

       
        .offer-btn-primary {
            background-color: var(--primary-color);
            color: #fff;
            font-weight: 500;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 0.3rem;
        }
        .offer-btn-secondary {
            background-color: #fff;
            color: var(--primary-color);
            border: 1px solid var(--primary-color);
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 0.3rem;
        }

    </style>
</head>
<body>

<div class="d-flex" id="wrapper">
    
    <div id="sidebar-wrapper">
        <div class="bg-white h-100">
            <div class="sidebar-heading text-center py-4 primary-text fs-4 fw-bold text-uppercase border-bottom-0">
               <div class="logo-box d-inline-block me-2">
                        <svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="40" height="36" fill="#F5F5F7"/>
                            <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                        </svg>
                    </div> 
            </div>
            <%- include('../partials/adminSideBar.ejs') %>
        </div>
    </div>

    <div id="page-content-wrapper" >
<%- include("../partials/notification.ejs")%>
<%- include('../partials/adminNavBar')%>

 <% if(status === "error"){%>
            <p class="alert alert-danger">Error! <%= message%></p>
           <%} %>

<div class="container-fluid">



 <form action="/admin/category/edit/<%= data._id %>" method="post" enctype="multipart/form-data">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-2">Edit Category</h2>
              <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
             <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted small">Dashboard</a></li>
             <li class="breadcrumb-item"><a href="/admin/categories" class="text-decoration-none text-muted small">Categories</a></li>
             <li class="breadcrumb-item active  text-primary small">Edit category</li>
                            </ol>
                </nav>
        </div>
        <div class="d-flex">
            <a href="/admin/categories" class="btn btn-light border me-3 fw-bold text-muted">
                <i class="bi bi-x fs-5 me-1"></i> Cancel
            </a>
           
            <button type="submit" class="btn btn-primary d-flex align-items-center fw-bold" style="background-color: var(--primary-color);">
                <i class="bi bi-save fs-5 me-1"></i> Save Category
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-4 mb-4 mb-md-0">
                    <h5 class="fw-bold mb-3 text-muted">Thumbnail</h5>
                    <div class="thumbnail-card bg-white">
                        <p class="fw-bold mb-2">Photo</p>
                        
                        <div class="image-placeholder-box">
                           
                            
                            <div class="bg-light rounded d-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                               
                                <img class="bi bi-image fs-3 text-muted" style="width: 100px; height: 100px; "src="<%= data.thumbnail.url %>">
                            </div>
                            <p class="text-muted small mb-1">Drag and drop image here, or</p>
                            <p class="text-muted small mb-3">click change image </p>
                            <input class="btn change-image-btn" name="image"  type="file" id="imageUpload" >
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <h5 class="fw-bold mb-3 text-muted">General Information</h5>
                    <div class="mb-5">
                        <label for="categoryName" class="form-label fw-bold">Category Name</label>
                        <input type="text" name="categoryName" value="<%= data.categoryName %>" class="form-control" id="categoryName" value="Watch" placeholder="Type category name here...">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</form>
</div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>