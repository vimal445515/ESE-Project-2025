<script src="/script/loader.js"></script>
    <script src="/script/tost.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let searchValue=""
        let productId = null
        function openDeleteModal(id){
            productId = id;
            const modal = new bootstrap.Modal(
                document.querySelector('#deleteModal')
            )
            modal.show();
        }
     function deleteProduct(){
        
            const modal = document.getElementById('deleteModal');
            bootstrap.Modal.getInstance(modal).hide();
            showLoader()
            fetch(`/admin/deleteProduct/${productId}`,{
                method:'DELETE'
            }).then(data=>data.json())
            .then(data=>{
                hideLoader()
                if(data?.type === 'error') return showToast(data.message,'error');
                showSuccessToast(data)})
             .catch(data=>
            {
            hideLoader()
            errorToast('something was wrong')
            }
        );
               setTimeout(()=>{
                  window.location.reload()
               },500)
           
           


        }

        function unDeleteProduct(productId){
            showLoader()
            fetch(`/admin/unDeleteProduct/${productId}`,{
                method:'PATCH'
            }).then(data=>data.json())
            .then(data=>{
                hideLoader()
                if(data?.type === 'error') return showToast(data.message,'error');
                showSuccessToast(data)})
            .catch(error=>{
                hideLoader()
                console.log(error)

            })
               setTimeout(()=>{
                  window.location.reload()
               },500)
            

        }


     

        function showSuccessToast(message){
            document.querySelector('#successTost .toast-body').innerText = message;
            const toast = new bootstrap.Toast(document.querySelector('#successTost'),{
                delay:3000,
                autohide:true
            })
            toast.show();
           
        }

        function setPage(page){
          
          correntPage = page
          window.location.href = `/admin/products?page=${correntPage}&search=${searchValue}`
        }

        function nextPage(correntPgae){
            showLoader()
           correntPgae++;
          setPage(correntPgae)  
             }
             function previousPage(page){
                showLoader()
                page--;
                if(page>0){
                     setPage(page)
                }
             }
        
              function debounce (fun,delay){
               
                let timer;
                return function(){
                    clearTimeout(timer);
                    timer = setTimeout(()=>{
                        fun()
                    },delay)
                }
             }

                 function searchText(){
                searchValue = document.getElementById('search').value
                document.getElementById('search').value = ''
                setPage(1)
             }

             const debounceSearch = debounce(searchText,1000);

             document.getElementById('search').addEventListener("input",debounceSearch)


             document.querySelector("#clear").addEventListener('click',()=>{
                console.log("hello")
                searchValue="";
                setPage(1)
             })

    </script>
    
</body>
