<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Report - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/adminStyles/sideBar.css">
    <link rel="stylesheet" href="/adminStyles/navBar.css">

    <style>
        :root {
            --sidebar-width: 250px;
            --primary-blue: #4054d2;
            --bg-light: #f5f6fa;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden; 
        }

        #page-content-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            min-height: 100vh;
        }

        /* Reusing your card and table styles for consistency */
        .report-card { border: none; border-radius: 15px; overflow: hidden; background: #fff; }
        
        .table thead th { 
            background-color: #fcfcfc; 
            color: #888; 
            font-weight: 500; 
            font-size: 0.8rem; 
            border-bottom: 1px solid #f1f1f1; 
            padding: 15px; 
        }

        .table tbody td { 
            padding: 15px; 
            vertical-align: middle; 
            border-bottom: 1px solid #f8f8f8; 
            font-size: 0.85rem; 
        }

        /* KPI Card Styles */
        .kpi-card {
            border: none;
            border-radius: 12px;
            padding: 20px;
            transition: transform 0.2s;
        }
        .kpi-card:hover { transform: translateY(-5px); }
        .icon-box {
            width: 45px;
            height: 45px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        /* Filter Section Styles */
        .filter-section {
            background: white;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
        }

        .btn-filter {
            border: 1px solid #dee2e6;
            background: white;
            color: #666;
            font-size: 0.85rem;
            font-weight: 500;
            padding: 8px 16px;
        }
        .btn-filter.active {
            background-color: var(--primary-blue);
            color: white;
            border-color: var(--primary-blue);
        }

        .btn-download {
            font-size: 0.85rem;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 8px;
        }
    </style>
</head>
<body>

    <div class="d-flex" id="wrapper">
        <div id="sidebar-wrapper">
            <div class="bg-white h-100 border-end">
                <div class="sidebar-heading text-center py-4 fs-4 fw-bold text-uppercase border-bottom-0">
                    <div class="logo-box d-inline-block me-2">
                        <svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="40" height="36" fill="#F5F5F7"/>
                            <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                        </svg>
                    </div> 
                </div>
                
                <%- include('../partials/adminSideBar.ejs') %>
            </div>
        </div>

        <div id="page-content-wrapper">
            <%- include('../partials/adminNavBar.ejs') %>

            <div class="container-fluid px-4 pt-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold mb-0">Sales Report</h4>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted small">Dashboard</a></li>
                                <li class="breadcrumb-item active small text-muted">Sales Report</li>
                            </ol>
                        </nav>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-danger btn-download">
                            <i class="bi bi-file-earmark-pdf me-2"></i>PDF
                        </button>
                        <button class="btn btn-outline-success btn-download">
                            <i class="bi bi-file-earmark-excel me-2"></i>Excel
                        </button>
                    </div>
                </div>

                <div class="filter-section shadow-sm">
                    <div class="row g-3 align-items-end">
                        <div class="col-lg-5">
                            <label class="form-label small fw-bold text-muted">Quick Filters</label>
                            <div class="btn-group w-100" role="group">
                                <button type="button" onclick="OneDay(new Date,new Date)" class="btn btn-filter">1 Day</button>
                                <button type="button" onclick="week()" class="btn btn-filter">Weekly</button>
                                <button type="button" onclick="month()" class="btn btn-filter">Monthly</button>
                                <button type="button" onclick="year() " class="btn btn-filter">Yearly</button>
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <label class="form-label small fw-bold text-muted">Custom Date Range</label>
                            <div class="input-group">
                                <input type="date" class="form-control form-control-sm">
                                <span class="input-group-text small">to</span>
                                <input type="date" class="form-control form-control-sm">
                            </div>
                        </div>
                        <div class="col-lg-2">
                            <button class="btn btn-primary w-100 btn-sm py-2" style="background-color: var(--primary-blue); border: none;">
                                Generate Report
                            </button>
                        </div>
                    </div>
                </div>

                        <div class="row g-4 mb-4">
                <div class="col-sm-6 col-md-4 col-xl">
                    <div class="kpi-card bg-white shadow-sm d-flex align-items-center">
                        <div class="icon-box bg-primary-subtle text-primary me-3">
                            <i class="bi bi-cart-check"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block font-size-xs">Overall Sales Count</small>
                            <h4 id="salesCount" value="<%= salesReportData[0].totalOrder%>" class="fw-bold mb-0">
                                <%= salesReportData[0].totalOrder%>
                            </h4>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-md-4 col-xl">
                    <div class="kpi-card bg-white shadow-sm d-flex align-items-center">
                        <div class="icon-box bg-success-subtle text-success me-3">
                            <i class="bi bi-currency-rupee"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block font-size-xs">Overall Order Amount</small>
                            <h4 id="orderAmount" value="<%= salesReportData[0].overalOrderAmount%>" class="fw-bold mb-0">
                                ₹<%= salesReportData[0].overalOrderAmount.toLocaleString('en-IN')%>
                            </h4>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-md-4 col-xl">
                    <div class="kpi-card bg-white shadow-sm d-flex align-items-center">
                        <div class="icon-box bg-danger-subtle text-danger me-3">
                            <i class="bi bi-tag"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block font-size-xs">Overall Discounts</small>
                            <h4 id="discountAmount" value="<%= salesReportData[0].overalDiscountAmount%>" class="fw-bold mb-0">
                                ₹<%= salesReportData[0].overalDiscountAmount.toLocaleString('en-IN')%>
                            </h4>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-md-4 col-xl">
                    <div class="kpi-card bg-white shadow-sm d-flex align-items-center">
                        <div class="icon-box bg-warning-subtle text-warning me-3">
                            <i class="bi bi-percent"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block font-size-xs">Total Tax (GST)</small>
                            <h4 id="taxAmount" value="<%= salesReportData[0].totalTax %>" class="fw-bold mb-0">
                                ₹<%= (salesReportData[0].overalTax || 0).toLocaleString('en-IN') %>
                            </h4>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-md-4 col-xl">
                    <div class="kpi-card bg-white shadow-sm d-flex align-items-center" style="border-bottom: 3px solid #0dcaf0;">
                        <div class="icon-box bg-info-subtle text-info me-3">
                            <i class="bi bi-wallet2"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block font-size-xs text-uppercase fw-semibold">Net Revenue</small>
                            <h4 id="revenue" value="<%= salesReportData[0].netSales%>" class="fw-bold mb-0 text-info">
                                ₹<%= salesReportData[0].netSales.toLocaleString('en-IN')%>
                            </h4>
                        </div>
                    </div>
                </div>
            </div>

                <div class="card report-card shadow-sm mb-5">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Date</th>
                                        <th>Order ID</th>
                                        <th>Customer</th>
                                        <th>Order Amount</th>
                                        <th>Discount</th>
                                        <th>Coupons</th>
                                        <th class="text-end pe-4">Final Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="ps-4">24 Oct 2023</td>
                                        <td class="fw-medium text-muted">#ORD-9921</td>
                                        <td>Rahul Sharma</td>
                                        <td>₹1,200.00</td>
                                        <td class="text-danger">-₹100.00</td>
                                        <td class="text-danger">-₹50.00</td>
                                        <td class="text-end pe-4 fw-bold text-success">₹1,050.00</td>
                                    </tr>
                                    <tr>
                                        <td class="ps-4">23 Oct 2023</td>
                                        <td class="fw-medium text-muted">#ORD-9918</td>
                                        <td>Anjali V.</td>
                                        <td>₹5,400.00</td>
                                        <td class="text-danger">-₹400.00</td>
                                        <td class="text-danger">-₹0.00</td>
                                        <td class="text-end pe-4 fw-bold text-success">₹5,000.00</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        //  logic for the filter button active state
        const filterBtns = document.querySelectorAll('.btn-filter');
        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });
        const salesCount= document.getElementById('salesCount');
        const orderAmount = document.getElementById('orderAmount');
        const discountAmount = document.getElementById('discountAmount');
        const revenue = document.getElementById('revenue');
        const tax = document.getElementById('taxAmount');
      function OneDay(startDate,endDate){
            startDate.setHours(0,0,0,0),
            endDate.setHours(23,59,59,999)
            fetch(`/reports?startDate=${startDate}&endDate=${endDate}`)
            .then(data=>data.json())
            .then(data=>{
                orderAmount.vaule = data.salesReportData[0].overalOrderAmount;
                salesCount.vaule = data.salesReportData[0].totalOrder;
                discountAmount.value = data.salesReportData[0].overalDiscountAmount;
                revenue.value = data.salesReportData[0].netSales

                orderAmount.innerText = `₹${data.salesReportData[0].overalOrderAmount.toLocaleString('en-IN')}`;
                salesCount.innerText = `${data.salesReportData[0].totalOrder.toLocaleString('en-IN')}`
                tax.innerText = `₹${data.salesReportData[0].overalTax.toLocaleString('en-IN')}`
                discountAmount.innerText = `₹${data.salesReportData[0].overalDiscountAmount.toLocaleString('en-IN')}`;
                revenue.innerText = `₹${data.salesReportData[0].netSales.toLocaleString('en-IN')}`;


            })
        }

        function week(){
            let startDate = new Date();
            startDate.setHours(0,0,0,0);
            let endDate = new Date()
            endDate.setHours(23,59,59,999);
            startDate.setDate(startDate.getDate()-7)
            fetch(`/reports?startDate=${startDate}&endDate=${endDate}`)
             .then(data=>data.json())
            .then(data=>{
                orderAmount.vaule = data.salesReportData[0].overalOrderAmount;
                salesCount.vaule = data.salesReportData[0].totalOrder;
                discountAmount.value = data.salesReportData[0].overalDiscountAmount;
                revenue.value = data.salesReportData[0].netSales

                 orderAmount.innerText = `₹${data.salesReportData[0].overalOrderAmount.toLocaleString('en-IN')}`;
                salesCount.innerText = `${data.salesReportData[0].totalOrder.toLocaleString('en-IN')}`
                tax.innerText = `₹${data.salesReportData[0].overalTax.toLocaleString('en-IN')}`
                discountAmount.innerText = `₹${data.salesReportData[0].overalDiscountAmount.toLocaleString('en-IN')}`;
                revenue.innerText = `₹${data.salesReportData[0].netSales.toLocaleString('en-IN')}`;


            })
         

        }

        function month(){
            let startDate = new Date(new Date().getFullYear(),new Date().getMonth(),1);
            let endDate = new Date();
            endDate.setHours(23,59,59,999);
            fetch(`/reports?startDate=${startDate}&endDate=${endDate}`)
             .then(data=>data.json())
            .then(data=>{
                orderAmount.vaule = data.salesReportData[0].overalOrderAmount;
                salesCount.vaule = data.salesReportData[0].totalOrder;
                discountAmount.value = data.salesReportData[0].overalDiscountAmount;
                revenue.value = data.salesReportData[0].netSales

                 orderAmount.innerText = `₹${data.salesReportData[0].overalOrderAmount.toLocaleString('en-IN')}`;
                salesCount.innerText = `${data.salesReportData[0].totalOrder.toLocaleString('en-IN')}`
                tax.innerText = `₹${data.salesReportData[0].overalTax.toLocaleString('en-IN')}`
                discountAmount.innerText = `₹${data.salesReportData[0].overalDiscountAmount.toLocaleString('en-IN')}`;
                revenue.innerText = `₹${data.salesReportData[0].netSales.toLocaleString('en-IN')}`;


            })
            
        }

        function year(){
            let startDate = new Date(new Date().getFullYear(),0,1)
            let endDate =  new Date()
            endDate.setHours(23,59,59,999)
            fetch(`/reports?startDate=${startDate}&endDate=${endDate}`)
             .then(data=>data.json())
            .then(data=>{
                orderAmount.vaule = data.salesReportData[0].overalOrderAmount;
                salesCount.vaule = data.salesReportData[0].totalOrder;
                discountAmount.value = data.salesReportData[0].overalDiscountAmount;
                revenue.value = data.salesReportData[0].netSales

                 orderAmount.innerText = `₹${data.salesReportData[0].overalOrderAmount.toLocaleString('en-IN')}`;
                salesCount.innerText = `${data.salesReportData[0].totalOrder.toLocaleString('en-IN')}`
                tax.innerText = `₹${data.salesReportData[0].overalTax.toLocaleString('en-IN')}`
                discountAmount.innerText = `₹${data.salesReportData[0].overalDiscountAmount.toLocaleString('en-IN')}`;
                revenue.innerText = `₹${data.salesReportData[0].netSales.toLocaleString('en-IN')}`;


            })
            
        }

    </script>
</body>
</html>