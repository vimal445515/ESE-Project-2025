<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Referral Offers - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/adminStyles/sideBar.css">
    <link rel="stylesheet" href="/adminStyles/navBar.css">

    <style>
        :root {
            --sidebar-width: 250px;
            --primary-blue: #4054d2;
            --bg-light: #f5f6fa;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden; 
        }

        #page-content-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            min-height: 100vh;
        }

        .offer-card { border: none; border-radius: 15px; overflow: hidden; background: #fff; }
        
        .table thead th { 
            background-color: #fcfcfc; 
            color: #888; 
            font-weight: 500; 
            font-size: 0.8rem; 
            border-bottom: 1px solid #f1f1f1; 
            padding: 15px; 
        }

        .table tbody td { 
            padding: 15px; 
            vertical-align: middle; 
            border-bottom: 1px solid #f8f8f8; 
            font-size: 0.85rem; 
        }

        .form-switch .form-check-input { width: 2.5em; height: 1.25em; cursor: pointer; }
        .form-check-input:checked { background-color: #0d9667; border-color: #0d9667; }

        .status-pill {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
        }
        .status-active { background-color: #e6f8f0; color: #0d9667; }
        .status-disabled { background-color: #f1f3f5; color: #6c757d; }

        .btn-create {
            background-color: var(--primary-blue);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
        }

        .reward-badge {
            background-color: #f0f2ff;
            color: var(--primary-blue);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="d-flex" id="wrapper">
        <div id="sidebar-wrapper">
            <div class="bg-white h-100 border-end">
                <div class="sidebar-heading text-center py-4 fs-4 fw-bold text-uppercase border-bottom-0">
                    <div class="logo-box d-inline-block me-2">
                        <svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="40" height="36" fill="#F5F5F7"/>
                            <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                        </svg>
                    </div> 
                </div>
                <%- include('../partials/adminSideBar.ejs') %>
            </div>
        </div>

        <div id="page-content-wrapper">
            <%- include('../partials/adminNavBar.ejs') %>

            <div class="container-fluid px-4 pt-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold mb-0">Referral Offers</h4>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="/offers" class="text-decoration-none text-muted small">Offers</a></li>
                                <li class="breadcrumb-item active small text-muted">Referral Offer</li>
                            </ol>
                        </nav>
                    </div>
                    <button class="btn btn-create" data-bs-toggle="modal" data-bs-target="#createReferralOfferModal">
                        <i class="bi bi-plus-lg me-2"></i> Create Offer
                    </button>
                </div>

                <div class="card offer-card shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Offer Name</th>
                                        <th>Referrer Reward</th>
                                        <th>Referee Reward</th>
                                        <th>Min. Purchase</th>
                                        <th>Status</th>
                                        <th>Enable/Disable</th>
                                        <th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="ps-4 fw-bold">Invite & Earn Program</td>
                                        <td><span class="reward-badge">₹500 Wallet</span></td>
                                        <td><span class="reward-badge">20% Discount</span></td>
                                        <td>₹1000</td>
                                        <td><span class="status-pill status-active">Active</span></td>
                                        <td>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" checked>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-link text-muted p-0 me-3" data-bs-toggle="modal" data-bs-target="#editReferralOfferModal">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn btn-link text-danger p-0">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="createReferralOfferModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold">Create Referral Offer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/admin/offers/referral/create" method="POST">
                    <div class="modal-body px-4 pb-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Offer Name</label>
                            <input type="text" class="form-control" name="offerName" placeholder="e.g. Friends Referral" required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Referrer Discount(%)</label>
                                <input type="text" class="form-control" name="referrerReward" placeholder="e.g. ₹100" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Minimum Purchase Amount</label>
                                <input type="number" class="form-control" name="minPurchase" placeholder="₹" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Expiry Date</label>
                                <input type="date" class="form-control" name="expiryDate" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4" style="background-color: var(--primary-blue); border: none;">Create Offer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editReferralOfferModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold">Edit Referral Offer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/admin/offers/referral/update" method="POST">
                    <input type="hidden" name="offerId" id="editReferralOfferId">
                    <div class="modal-body px-4 pb-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Offer Name</label>
                            <input type="text" class="form-control" name="offerName" id="editReferralOfferName" required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Referrer Discount(%)</label>
                                <input type="text" class="form-control" name="referrerReward" id="editReferrerReward" required>
                            </div>
                           
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Minimum Purchase Amount</label>
                                <input type="number" class="form-control" name="minPurchase" id="editMinPurchase" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Expiry Date</label>
                                <input type="date" class="form-control" name="expiryDate" id="editReferralExpiry" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4" style="background-color: var(--primary-blue); border: none;">Update Offer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>