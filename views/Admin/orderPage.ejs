<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order List - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link  rel="stylesheet" href="/adminStyles/sideBar.css">
    <link rel="stylesheet" href="/adminStyles/navBar.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/UserStyles/loader.css">

    
    <style>
        :root {
            --sidebar-width: 250px;
            --primary-blue: #4054d2;
            --bg-light: #f5f6fa;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden; 
        }

        
        #page-content-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            min-height: 100vh;
        }

        
        .order-card { border: none; border-radius: 15px; overflow: hidden; background: #fff; }
        .table thead th { background-color: #fcfcfc; color: #888; font-weight: 500; font-size: 0.8rem; border-bottom: 1px solid #f1f1f1; padding: 15px; }
        .table tbody td { padding: 15px; vertical-align: middle; border-bottom: 1px solid #f8f8f8; font-size: 0.85rem; }

        
 
        .status-pill {
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
        }
        .status-processing { background-color: #f0f2ff; color: #4054d2; }
        .status-shipped { background-color: #f1f3f5; color: #6c757d; }
        .status-delivered { background-color: #e6f8f0; color: #0d9667; }
        .status-canceled { background-color: #ffeaea; color: #ff4d4d; }
        .status-return {background-color:#ffeaea; color: #ff00ff;}

        .pay-badge {
            padding: 3px 10px;
            border-radius: 6px;
            font-size: 11px;
            border: 1px solid transparent;
        }
        .pay-online { background: #E9FAF7; color: #1A9882; border-color: #1A9882; }
        .pay-cod { background: #FEECEE; color: #EB3D4D; border-color: #EB3D4D; }

        
        .page-link { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 50% !important; margin: 0 3px; font-size: 0.8rem; border: 1px solid #eee; color: #666; }
        .active-page { background-color: var(--primary-blue) !important; color: white !important; border: none !important; }
    </style>
</head>
<body>
   
    <div class="d-flex" id="wrapper">
        <div id="sidebar-wrapper">
             <div class="bg-white" id="sidebar-wrapper">
            <div class="sidebar-heading text-center py-4 primary-text fs-4 fw-bold text-uppercase border-bottom-0">
                <div class="logo-box d-inline-block me-2"><svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
