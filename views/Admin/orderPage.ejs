                <rect width="40" height="36" fill="#F5F5F7"/>
                <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                </svg></div> 
            </div>
            <%- include('../partials/adminSideBar.ejs') %>
        </div>

        <div id="page-content-wrapper">
            
            <%- include('../partials/adminNavBar.ejs') %>
            <%- include('../partials/notification')%>
             <%- include("../partials/loader")%>
            <div class="container-fluid px-4">
                <div class="d-flex justify-content-between">
                  <div class=" ms-2  input-group d-flex " style="max-width: 400px;">
                  
                    <input type="text" id="searchInput" value="<%= search%>" name="value" class="form-control" placeholder="Search..." aria-label="Search" required>
                    <button type="button" onclick="searchText()" id="search"  class="btn btn-light">Search</button>
                
                     <button class="btn btn-light" onclick="showNotification()">
                      <i class="bi bi-bell"></i>
                    </button>

                                
                        <div class="modal fade" id="popupModal" tabindex="-1">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                            <div class="modal-header bg text-white">
                                <h5 class="modal-title">Message</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                               <h5 class="mb-3">Return requests</h5>

                                <div class="card" >
                                    <div class="card-body ">

                                    <!-- Scrollable area -->
                                    <div class="list-group overflow-auto" style="max-height: 250px;">
                                        <table class="table table-bordered table-hover text-center align-middle">
                                                <thead class="table-dark">
                                                <tr>
                                                    <th>Type</th>
                                                    <th>Product Name</th>
                                                    <th>Reason</th>
                                                    <th>Order Details</th>
                                                    <th>Action</th>
                                                </tr>
                                                </thead>
                                                 <tbody>
                                                 <% notifications.forEach((request)=>{%>  
                                                <tr>
                                                    <td><%= request.type%></td>
                                                    <td><%= request?.product?request.product.productName:'All Products'%></td>
                                                    <td><p class="mb-1"><%= request.reason%></p></td>
                                                    <td> <a href="/admin/order/edit/<%= request.orderId%>" class="small">Order details</a></td>
                                                    <td class="d-flex">
                                                    <button onclick="accept(`<%= request.orderId%>`,`<%=request.type%>`,`<%= request?.product?.productId%>`,`<%= request?.product?.variantId%>`)" class="btn btn-success btn-sm">Accept</button>
                                                    <button onclick="reject(`<%= request.orderId%>`,`<%=request.type%>`,`<%= request?.product?.productId%>`,`<%= request?.product?.variantId%>`)" class="btn btn-danger btn-sm">Reject</button>
                                                    </td>
                                                </tr>

                                           <% })%>   
                                              </tbody>
                                                </table> 
                                    </div>

                                    </div>
                                </div>
                            </div>
                            </div>
                        </div>
                        </div>

                       
                       


            </div>

             <div class="d-flex align-items-center small text-muted me-2">
                     <a id="clear" href="/admin/order" class="btn btn-light me-2">Clear</a>
                    <label for="sortPrice" class="me-2 text-nowrap">Sort By:</label>
                    <select class="form-select form-select-sm" id="sort" style="width: auto;">
                        <option value="" >sort</option>
                        <option value="ltoH" <%= sort === 'ltoH' ? 'selected' : '' %>>Low to high</option>
                        <option value="htoL" <%= sort === 'htoL' ? 'selected' : '' %>>High to low</option>
                        <option value="new"  <%= sort === 'new' ? 'selected' : '' %> >New to old</option>
                        <option value="old"  <%= sort === 'old' ? 'selected' : '' %>>old to New</option>
                    </select>


                      <label for="sortPrice" class="mx-2 text-nowrap">filter:</label>
                    <select class="form-select form-select-sm" id="filter" style="width: auto;">
                        <option value="" >filter</option>
                         <option value="processing" <%= filter === 'processing' ? 'selected' : '' %>> Processing</option>
                        <option value="shipped" <%= filter === 'shipped'?'selected':''%>>Shipped</option>
                        <option value="delivered" <%= filter === 'delivered'?'selected':''%>>Delivered</option>
                        <option value="canceled" <%= filter === 'canceled'?'selected':''%>>canceled</option>
                    </select>
                </div>
                </div>




            <div class="container-fluid px-4 mt-3">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold mb-0">Order</h4>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-decoration-none text-muted small">Dashboard</a></li>
                                <li class="breadcrumb-item text-primary active small">Order List</li>
                            </ol>
                        </nav>
                    </div>
                   
                </div>

                <div class="card order-card shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4"><input type="checkbox" class="form-check-input me-2"> Order ID</th>
                                        <th>Product</th>
                                        <th>Date</th>
                                        <th>Customer</th>
                                        <th>Total</th>
                                        <th>Payment</th>
                                        <th>Status</th>
                                        <th class="text-end pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% orders.forEach(order=>{%>
                                    <tr>
                                        <td class="ps-4 fw-bold text-primary"><%= order.orderId%></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div>
                                                    <div class="fw-bold small"><%= order.items[0]?.productName%></div>
                                                    <small class="text-muted">+<%= order.items.length-1||'only one'%> Products</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-muted small"><%= order.createdAt.toISOString().slice(0,10)%></td>
                                        <td class="small"><%= order.address.userName%></td>
                                        <td class="fw-bold">₹<%= order.pricing.totalAmount.toLocaleString('en-IN')%></td>
                                        <% if(order.payment.method === 'cod'){%>
                                             <td><span class="pay-badge pay-cod">Cash on delivery</span></td>
                                        <%}else{%>
                                             <td><span class="pay-badge pay-online">Online</span></td>
                                         <%}%>
                                        
                                       
                                       <% if(order.orderStatus === 'placed'){%>
                                        <td><span class="status-pill status-processing">Processing</span></td>
                                        <%}else if(order.orderStatus === 'shipped'){%>
                                        <td><span class="status-pill status-shipped">Shipped</span></td>
                                        <%}else if(order.orderStatus === 'return'){%>
                                        <td><span class="status-pill status-return">Return</span></td>
                                        <%}else if(order.orderStatus === 'delivered'){%>
                                             <td><span class="status-pill status-delivered">Delivered</span></td>
                                             <%}else if(order.orderStatus === 'canceled'){%>
                                                     <td><span class="status-pill status-canceled">canceled</span></td>
                                           <%}%>
                                        <td class="text-end pe-4">
                                            <a href="/admin/order/edit/<%= order._id%>" class="btn btn-link text-muted p-0 me-2"><i class="fas fa-pencil-alt"></i></a>
                                            <% if(!order.isDeleted){%>
                                            <form class="unlistForm" action="order/delete" method="post">
                                            <input type="hidden" name="isDeleted" value="true">
                                            <input type="hidden" name="orderId" value="<%=order._id%>">
                                            <button onclick="showModal('<%=order._id%>')" class="btn btn-link text-muted p-0"><i class="btn btn-danger">Unlist</i></button>
                                            </form>
                                            <%}else{%>
                                            <form action="order/delete" method="post">
                                            <input type="hidden" name="isDeleted" value="false">
                                            <input type="hidden" name="orderId" value="<%=order._id%>">
                                            <button class="btn btn-success">List</button>
                                           </form>
                                            <%}%>
                                        </td>
                                    </tr>
                                   <%})%>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-white border-0 py-3 ps-4 pe-4 d-flex justify-content-between align-items-center">
                        <small class="text-muted fw-bold">Showing <%=page%>-<%=parseInt(count/limit)%> from <%=count%></small>
                        <nav aria-label="Page navigation">
                            <ul class="pagination mb-0">
                                <li class="page-item"><button onclick="previousPage('<%= page%>')" class="page-link" href=""><i class="fas fa-arrow-left"></i></button></li>
                                 <% for(let i = 1; i <= (count/limit)+1; i++) {%> 
                                <li class="page-item"><button id="page" onclick="search('<%= i%>')" value="<%= i %>" class="page-link active-page" ><%= i%></button></li>
                                 <% } %>
                                <li class="page-item"><button class="page-link" onclick="nextPage('<%= page%>')"><i class="fas fa-arrow-right"></i></button></li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>

                                         <div class="modal fade" id="unlistModal">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Unlist Order</h5>
                                                        </div>
                                                        <div class="modal-body">
                                                            Are you sure you want to Unlist this order
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button class="btn btn-danger" onclick="unlistOrder()"  >Unlist</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
        

    <script>
         let correntPage = '<%= page%>';
         let sort = "<%= sort%>"
         let searchValue = "<%= search%>"
         let filter  = "<%= filter%>"
         function search(page){
          correntPage = page
          showLoader()
          window.location.href = `/admin/order?page=${correntPage}&sort=${sort}&search=${searchValue}&filter=${filter}`
        }
         function nextPage(correntPgae){
           correntPgae++;
          search(correntPgae)  
             }

        function previousPage(page){
                page--;
                if(page>0){
                     search(page)
                }
             }
        function searchText(){
          searchValue =   document.getElementById("searchInput").value
          search(1)
        }

         document.getElementById('sort').addEventListener('change',()=>{
        sort = document.getElementById('sort').value
        search(1)
        })

      document.getElementById('filter').addEventListener('change',()=>{
        filter = document.getElementById('filter').value
        search(1)
        })

        function showNotification(){
            const modal = new bootstrap.Modal(document.getElementById('popupModal'));
                        modal.show();
        }

        function reject(orderId,type,productId,variantId){
            if(window.confirm("are you shure you what to reject the request!")){
                showLoader()
                fetch(`/admin/order/reject/${orderId}?type=${type}&productId=${productId}&variantId=${variantId}`)
            .then((data)=>{
                hideLoader()
                window.location.reload()
            }).catch(error=>{
                console.log(error)
            })
            }
            
        }

        function accept(orderId,type,productId,variantId){
            if(window.confirm("are you shure you what to accept the request !")){
                showLoader()
                fetch(`/admin/order/accept/${orderId}?type=${type}&productId=${productId}&variantId=${variantId}`)
                .then((data)=>{
                    hideLoader()
                    window.location.reload()
                })
            }
        }
         
        let orderId;
        let unlistForm;
        let unlistForms = document.querySelectorAll(".unlistForm");
        unlistForms.forEach(form=>{
            form.addEventListener('submit',(e)=>{
            unlistForm = e.target;
            e.preventDefault()
             let modalElement = document.getElementById("unlistModal");
            let modal = new bootstrap.Modal(modalElement)
            modal.show()
        })


        })
        function unlistOrder(){
            unlistForm.submit()
        }
      
    </script>
    <script src="/script/loader.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>