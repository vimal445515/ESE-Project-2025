</div>
 <div class="d-flex justify-content-end pb-4">
        <button type="submit" onclick="clean()" class="btn btn-primary btn-lg px-5 fw-bold me-2">Clear</button>
        <button onclick="add()" id="addButton" class="btn btn-primary btn-lg px-5 fw-bold">Add</button>
        <button onclick="save()" id="saveButton" class="btn btn-primary btn-lg px-5 fw-bold" style="display:none">Save</button>
