                        <p id="img1Error" class="text-danger small"></p>
                    </div>
                      <div class="input-group"><label class="input-group-text image-label" for="img2"> <img id="previewImg2" class="previewImg" alt="preview"> </label><input type="file" name="img2"  class="form-control" id="img2">
                    <p id="img2Error" class="text-danger small"></p>
                    </div>
                       <div class="input-group"><label class="input-group-text image-label" for="img3"> <img id="previewImg3" class="previewImg" alt="preview"> </label><input type="file" name="img3"  class="form-control" id="img3">
                    <p id="img3Error" class="text-danger small"></p>
                    </div>
