function preview(e){
   const image =  e.files[0]
   const parent = e.closest('.input-group')
   parent.querySelector('.previewImg').src= URL.createObjectURL(image);
}

    function showLoader() {
  document.getElementById("globalLoader").classList.remove("d-none");
}

function hideLoader() {
  document.getElementById("globalLoader").classList.add("d-none");
}


function removeVariant(){
    objectArray.splice(index,1);
    let divArea = [];
    for(i = 0; i < objectArray?.length||0; i++){
            button = `
            <button type='button' onclick='selectVariant(${i})' class="variant-pill  bg-success me-2 text-white">${i+1}</button>
            `
        divArea.push(button)
        }
    modal.hide()
        document.querySelector('.variantSelect').innerHTML = divArea.join("")
        clean()
