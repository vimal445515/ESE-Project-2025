     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
     <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
<script>
    const objectArray = []
    let cropper;
    let croppedBlob;
     let i;
     let index;
    const inputImage = document.getElementById('inputImage');
    const image = document.getElementById('image');
    const cropButton = document.getElementById('cropButton');
    const croppedResult = document.getElementById('croppedResult');

    const cropModal = new bootstrap.Modal(document.getElementById('cropModal'));

    
    document.getElementById('cropModal')
  .addEventListener('shown.bs.modal', () => {
    if (cropper) {
      cropper.resize();
      cropper.reset();
    }
    });

    // Open modal on image select
    inputImage.addEventListener('change', (e) => {

      const file = e.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = () => {
        image.src = reader.result;
        cropModal.show();

        if (cropper) cropper.destroy();

        cropper = new Cropper(image, {
          aspectRatio: 4/3,
          viewMode: 1,
          autoCropArea: 0.8,
          cropBoxResizable:false,
           autoCropArea: 1
         

        });
      };
      reader.readAsDataURL(file);
    });

    // Crop inside modal
    cropButton.addEventListener('click', () => {
      const canvas = cropper.getCroppedCanvas({
        width: 256,
        height: 256
      });

      canvas.toBlob((blob) => {
        croppedBlob = blob;

        const previewURL = URL.createObjectURL(blob);
        croppedResult.innerHTML = `<img src="${previewURL}">`;
        cropModal.hide();
      }, 'image/jpeg', 0.8);
    });


    function showError(id, message) {
    document.getElementById(id).innerText = message;
}

   function clearErrors() {
    document.querySelectorAll(".text-danger").forEach(el => el.innerText = "");
   }

    function add(){

            
            const price = document.querySelector("#price").value;
            const stock = document.querySelector("#stock").value;
            const storage =  document.querySelector("#storage").value;
            const ram = document.querySelector("#ram").value;
            const img1 =   document.querySelector("#img1").files[0];
            const img2 =   document.querySelector("#img2").files[0];
            const img3 =   document.querySelector("#img3").files[0];
            const img4 =   document.querySelector("#img4").files[0];

         let valid = true;

    if (!storage || isNaN(storage)) { showError("storageError", "Storage is invalid."); valid = false; }
    if (!ram || isNaN(storage)) { showError("ramError", "RAM is invalid."); valid = false; }

    if (!price || isNaN(price) || Number(price) <= 0) {
        showError("variantPriceError", "Enter a valid price."); valid = false;
    }

    if (!stock || isNaN(stock)|| Number(stock) < 0) {
        showError("stockError", "Enter valid stock."); valid = false;
    }

    if (!img1) { showError("img1Error", "Image 1 required."); valid = false; }
    if (!img2) { showError("img2Error", "Image 2 required."); valid = false; }
    if (!img3) { showError("img3Error", "Image 3 required."); valid = false; }
    if (!img4) { showError("img4Error", "Image 4 required."); valid = false; }

    if (!valid) return;


           const group = {
            price,
            stock,
            storage,
            ram,
            img1,
            img2,
            img3,
            img4
        }
       for(let value of objectArray)
       {
        if(price ===value.price && stock === value.stock && storage ===value.storage && ram == value.ram)
       {
        alert("Repeat varients not allowed");
        return
       }
       }

     objectArray.push(group);
     console.log("value",group)
     console.log("Values ",objectArray)

        // selecting variants
        let button
        let divArea = [];
       
        for(i = 0; i < objectArray?.length||0; i++){
            button = `
            <button type='button' onclick='selectVariant(${i})' class="variant-pill  bg-success me-2 text-white">${i+1}</button>
            `
        divArea.push(button)
        }
        
        document.querySelector('.variantSelect').innerHTML = divArea.join("")
        // document.getElementById('storage').value = ""
        // document.getElementById('ram').value = ""
        // document.getElementById('stock').value = ""
        // document.getElementById('price').value = ""

        // document.getElementById('img1').value = ''
        // document.getElementById('img2').value = ''
        // document.getElementById('img2').value = ''
        // document.getElementById('img2').value = ''

    }

     const modalElement = document.getElementById('confirmRemoveVariantModal');
    const modal = new  bootstrap.Modal(modalElement);


    function saveData() {

         clearErrors();
         document.querySelector('.removeButton').classList.add('d-none')
         const productName = document.querySelector("#productName").value;
            const description = document.querySelector("#description").value;
            const basePrice   = document.querySelector("#basePrice").value;
            const discount = document.querySelector("#discount").value;
            const category = document.querySelector("#productCategory").value

        
            let valid = true;

            if (!productName) { showError("productNameError", "Product name required."); valid = false; }
            if (!description) { showError("descriptionError", "Description required."); valid = false; }

            if (!basePrice || isNaN(basePrice) || Number(basePrice) <= 0) {
                showError("basePriceError", "Enter valid base price."); valid = false;
            }

            if (!discount || isNaN(discount) || Number(discount) < 0 || Number(discount) > 99) {
                showError("discountError", "Discount must be between 0–99."); valid = false;
            }

            if (!croppedBlob) { showError("generalImageError", "General image required."); valid = false; }

            if (!category || category === "Select a category") {
                showError("categoryError", "Select a category."); valid = false;
            }

            if (objectArray.length === 0) {
                alert("Please add at least one variant.");
                valid = false;
            }

            if (!valid) return;



        const formData = new FormData()
       
        objectArray.forEach((group,localIndex)=>{
            formData.append(`price${localIndex}`,group.price)
            formData.append(`stock${localIndex}`,group.stock)
            formData.append(`storage${localIndex}`,group.storage)
            formData.append(`ram${localIndex}`,group.ram)
            formData.append(`img1${localIndex}`,group.img1)
            formData.append(`img2${localIndex}`,group.img2)
            formData.append(`img3${localIndex}`,group.img3)
            formData.append(`img4${localIndex}`,group.img4)
        })

        formData.append(`productName`,productName)
        formData.append(`basePrice`,basePrice)
        formData.append(`description`,description)
        formData.append(`discound`,discount)
        formData.append(`generalPhoto`,croppedBlob);
        formData.append(`category`,category);
        console.log('formData:',formData)
        showLoader();
        fetch('/admin/product/add',{
            method:'POST',
            body:formData
        }).then(data =>data.json())
        .then(data =>{
            if(data?.type){
                if(data?.type ==='error'){
                     hideLoader();
                showToast(data.message,'error');
                return
                }
            }
             if(data?.obj){
              data =  data.obj.split('/')
              data = data[data.length-1]
              return  window.location.href = `/admin/addProduct`;
            }else{
                 hideLoader();
                showToast(data)
            }
        }).catch(()=>{
         hideLoader();
        showToast("Somthing was worng",'error')
        })
       
    }

    function clean(){
        
         

    document.querySelector("#price").value = "";
    document.querySelector("#stock").value = "";
    document.querySelector("#storage").value = "";
    document.querySelector("#ram").value = "";
    document.querySelector("#img1").value = "";
    document.querySelector("#img2").value = "";
    document.querySelector("#img3").value = "";
    document.querySelector("#img4").value = "";

    console.log("All fields cleared!");
       

    }


    // select variants function 
   function selectVariant(localIndex){

    index =localIndex;
        console.log(objectArray)
        document.getElementById('storage').value=objectArray[index].storage
        document.getElementById('ram').value=objectArray[index].ram
        document.getElementById('stock').value=objectArray[index].stock
        document.getElementById('price').value=objectArray[index].price
        const dataTransfer1 = new DataTransfer()
        document.getElementById('img1').value = ""
        dataTransfer1.items.add(objectArray[index].img1)
        document.getElementById('img1').files = dataTransfer1.files
        document.querySelector('#previewImg1').src = URL.createObjectURL(document.getElementById('img1').files[0]);

        const dataTransfer2 = new DataTransfer()
        document.getElementById('img2').value = ""
        dataTransfer2.items.add(objectArray[index].img2)
        document.getElementById('img2').files = dataTransfer2.files
        document.querySelector('#previewImg2').src = URL.createObjectURL(document.getElementById('img2').files[0]);

        const dataTransfer3 = new DataTransfer()
        document.getElementById('img3').value = ""
        dataTransfer3.items.add(objectArray[index].img3)
        document.getElementById('img3').files = dataTransfer3.files
        document.querySelector('#previewImg3').src = URL.createObjectURL(document.getElementById('img3').files[0]);

         const dataTransfer4 = new DataTransfer()
        document.getElementById('img4').value = ""
        dataTransfer4.items.add(objectArray[index].img4)
        document.getElementById('img4').files = dataTransfer4.files
        document.querySelector('#previewImg4').src = URL.createObjectURL(document.getElementById('img4').files[0]);

        document.getElementById('addButton').style.display = 'none'
        document.getElementById('saveButton').style.display = 'block';
        document.querySelector('.removeButton').classList.remove('d-none')
    }


    function save(){

           clearErrors();
         const price = document.querySelector("#price").value;
            const stock = document.querySelector("#stock").value;
            const storage =  document.querySelector("#storage").value;
            const ram = document.querySelector("#ram").value;
            const img1 =   document.querySelector("#img1").files[0];
            const img2 =   document.querySelector("#img2").files[0];
            const img3 =   document.querySelector("#img3").files[0];
            const img4 =   document.querySelector("#img4").files[0];

         let valid = true;

