<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
        <link rel="stylesheet" href="/adminStyles/sideBar.css">
    <link rel="stylesheet" href="/adminStyles/navBar.css">
</head>
<style>
    :root {
        --sidebar-width: 250px;
        --primary-blue: #4054d2; 
        --bg-light: #f5f6fa;
    }

    body { 
        background-color: var(--bg-light); 
        font-family: 'Poppins', sans-serif;
        overflow-x: hidden; 
    }

   
    #page-content-wrapper {
        margin-left: var(--sidebar-width);
        width: calc(100% - var(--sidebar-width));
        min-height: 100vh;
        transition: margin .25s ease-out;
    }

    #sidebar-wrapper {
        min-height: 100vh;
        width: var(--sidebar-width);
        position: fixed; 
        left: 0;
        z-index: 1000;
        transition: margin .25s ease-out;
    }

   
    .content-body {
        padding: 20px;
        width: 100%;
    }
    
    .dashboard-title {
        display: inline-block;
        border-bottom: 2px dotted #4054d2;
        padding-bottom: 5px;
    }

    
    .border-dotted {
        border: 1.5px dotted #a4b0f0 !important;
    }

    .extra-small {
        font-size: 0.75rem;
    }

   
    .progress-bar {
        background-color: #4054d2 !important;
    }

    .stat-card h3 {
        color: #333;
    }

    #chart-container {
        border: 1px dashed #ddd; 
    }

   
    .card-sunset { background: linear-gradient(135deg, #c91928 0%, #ffc371 100%); }
    .card-emerald { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
    .card-ocean { background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%); }

    .premium-card {
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

   
    .glass-icon {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 15px;
        border-radius: 50%;
        width: 65px;
        height: 65px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.2);
    }


    .premium-card:hover {
        transform: scale(1.05);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2) !important;
    }

    
    .premium-card::before {
        content: '';
        position: absolute;
        top: -20px;
        right: -20px;
        width: 100px;
        height: 100px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }

    .tracking-wider {
        letter-spacing: 0.1rem;
    }
</style>
</style>


</style>
<body>
    
<%- include("../partials/notification.ejs")%>

<div class="d-flex" id="wrapper">
    <div id="sidebar-wrapper">
        <div class="bg-white h-100">
            <div class="sidebar-heading text-center py-4 primary-text fs-4 fw-bold text-uppercase border-bottom-0">
                <div class="logo-box d-inline-block me-2">
                        <svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="40" height="36" fill="#F5F5F7"/>
                            <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                        </svg>
                    </div>
            </div>
            <%- include('../partials/adminSideBar.ejs') %>
        </div>
    </div>

    <div id="page-content-wrapper">
        
        <%- include('../partials/adminNavBar.ejs') %>

   <div class="content-body container-fluid px-4 pt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold dashboard-title">Dashboard</h2>
        </div>
    </div>
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card premium-card card-sunset p-4 shadow-lg rounded-4 d-flex justify-content-between align-items-center border-0">
            <div class="text-white">
                <p class="text-white-50 small mb-1 fw-bold tracking-wider">TODAYS SALES</p>
                <h2 class="fw-bold mb-0">₹1,00,999</h2>
                <div class="mt-2 small">
                    <span class="badge bg-white bg-opacity-25">+12.5% ↑</span>
                </div>
            </div>
            <div class="glass-icon">
                <i class="fas fa-shopping-cart"></i> <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card premium-card card-emerald p-4 shadow-lg rounded-4 d-flex justify-content-between align-items-center border-0">
            <div class="text-white">
                <p class="text-white-50 small mb-1 fw-bold tracking-wider">TODAYS REVENUE</p>
                <h2 class="fw-bold mb-1">₹30,000</h2>
                <p class="extra-small mb-0 text-white-50 italic">Profit made so far</p>
            </div>
            <div class="glass-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card premium-card card-ocean p-4 shadow-lg rounded-4 d-flex justify-content-between align-items-center border-0">
            <div class="text-white">
                <p class="text-white-50 small mb-1 fw-bold tracking-wider">TOTAL USERS</p>
                <h2 class="fw-bold mb-1">20,390</h2>
                <p class="extra-small mb-0 text-white-50">New signups today</p>
            </div>
            <div class="glass-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
        </div>
    </div>
</div>

   <div class="row g-4">
    <div class="col-lg-8">
        <div class="p-4 bg-white border-dotted rounded-4 h-100 shadow-sm overflow-hidden position-relative">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start mb-4 gap-3">
                <div>
                    <p class="text-muted small mb-0 fw-bold text-uppercase tracking-wider">Total Revenue Analysis</p>
                    <h2 class="fw-bold display-6">₹50,23,780</h2>
                </div>

                <div class="selection-bar d-flex gap-2 p-2 rounded-3 bg-light shadow-inner">
                    <div class="select-group">
                        <label class="select-label">Frequency</label>
                        <select class="form-select border-0 bg-transparent py-0">
                            <option>Daily</option>
                            <option selected>Monthly</option>
                            <option>Yearly</option>
                        </select>
                    </div>
                    <div class="vr mx-1 opacity-10"></div>
                    <div class="select-group">
                        <label class="select-label">Year</label>
                        <select class="form-select border-0 bg-transparent py-0">
                            <option selected>2026</option>
                            <option>2025</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 small fw-bold mb-4">
            </div>
            
            <div id="chart-container"  class="d-flex align-items-center justify-content-center chart-glass rounded-4">
                
                <div style="width: 100%; height: auto;"> <canvas id="myChart"></canvas> </div>

             
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="p-4 bg-white border-dotted rounded-4 h-100 shadow-sm">
            <h5 class="fw-bold mb-3">Top Performing</h5>
            
            <div class="mb-4 d-flex flex-column gap-2">
                <div class="p-2 bg-ocean-light rounded-3">
                    <label class="select-label text-ocean fw-bold">Filter Category</label>
                    <select class="form-select form-select-sm border-0 bg-transparent shadow-none">
                        <option selected>All Categories</option>
                        <option>Electronics</option>
                        <option>Fashion</option>
                    </select>
                </div>
            </div>
            
            <hr class="opacity-10 mb-4">

            <div class="space-y-4">
                <div class="mb-3">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="fw-medium">Phone</span> <span class="fw-bold text-primary">70%</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 8px;">
                        <div class="progress-bar gradient-primary" style="width: 70%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="fw-medium">Laptop</span> <span class="fw-bold text-primary">40%</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 8px;">
                        <div class="progress-bar gradient-primary" style="width: 40%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="fw-medium">Watch</span> <span class="fw-bold text-primary">60%</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 8px;">
                        <div class="progress-bar gradient-primary" style="width: 60%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="fw-medium">Tablet</span> <span class="fw-bold text-primary">100%</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 8px;">
                        <div class="progress-bar gradient-primary" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
    </div> </div> 
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>

    const monthlySales = {
  'january': 50,
  'february': 90,
  'march': 30,
  'april': 65,
  'may': 20,
  'june': 32,
  'july': 80,
  'august': 60,
  'september': 5,
  'october': 50,
  'november': 80,
  'december': 109
};
   chart(monthlySales);
  function chart(data,labels){
    console.log(Object.keys(data))
    const ctx = document.getElementById('myChart');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: Object.keys(data),
      datasets: [{
        label: 'Profit',
         borderColor: '#4054d2',
         backgroundColor: '#4054d2 ',
        data: Object.values(data),
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });

  }

</script>
</body>
</html>