<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Offers - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/adminStyles/sideBar.css">
    <link rel="stylesheet" href="/adminStyles/navBar.css">

    <style>
        :root {
            --sidebar-width: 250px;
            --primary-blue: #4054d2;
            --bg-light: #f5f6fa;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden; 
        }

        #page-content-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            min-height: 100vh;
        }
         .pagination-container {
            padding: 30px;
            display: flex;
            justify-content: center;
            gap: 10px;
        }

        .page-link-custom {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #ddd;
            color: #666;
            text-decoration: none;
            transition: all 0.2s;
            background: white;
            font-weight: 500;
        }
         .page-arrow { font-size: 1.1rem; color: var(--primary-blue); }

        .page-link-custom:hover {
            background-color: #f8f9fa;
            color: var(--primary-blue);
            border-color: var(--primary-blue);
        }

        .offer-card { border: none; border-radius: 15px; overflow: hidden; background: #fff; }
        
        .table thead th { 
            background-color: #fcfcfc; 
            color: #888; 
            font-weight: 500; 
            font-size: 0.8rem; 
            border-bottom: 1px solid #f1f1f1; 
            padding: 15px; 
        }

        .table tbody td { 
            padding: 15px; 
            vertical-align: middle; 
            border-bottom: 1px solid #f8f8f8; 
            font-size: 0.85rem; 
        }

        .form-switch .form-check-input { width: 2.5em; height: 1.25em; cursor: pointer; }
        .form-check-input:checked { background-color: #0d9667; border-color: #0d9667; }

        .status-pill {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
        }
        .status-active { background-color: #e6f8f0; color: #0d9667; }
        .status-disabled { background-color: #f1f3f5; color: #6c757d; }

        .btn-create {
            background-color: var(--primary-blue);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="d-flex" id="wrapper">
        <div id="sidebar-wrapper">
            <div class="bg-white h-100 border-end">
                <div class="sidebar-heading text-center py-4 fs-4 fw-bold text-uppercase border-bottom-0">
                    <div class="logo-box d-inline-block me-2">
                        <svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="40" height="36" fill="#F5F5F7"/>
                            <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                        </svg>
                    </div> 
                </div>
                <%- include('../partials/adminSideBar.ejs') %>
            </div>
        </div>

        <div id="page-content-wrapper">
            <%- include('../partials/adminNavBar.ejs') %>
            <%- include('../partials/notification.ejs')%>
            <div class="container-fluid px-4 pt-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold mb-0">Product Offers</h4>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="/offers" class="text-decoration-none text-muted small">Offers</a></li>
                                <li class="breadcrumb-item activesmall text-muted">Product Offer</li>
                            </ol>
                        </nav>
                    </div>
                    <button class="btn btn-create" data-bs-toggle="modal" data-bs-target="#createProductOfferModal">
                        <i class="bi bi-plus-lg me-2"></i> Create Offer
                    </button>
                </div>

                <div class="card offer-card shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Offer Name</th>
                                        <th>Product</th>
                                        <th>Discount (%)</th>
                                        <th>Expiry Date</th>
                                        <th>Status</th>
                                        <th>Enable/Disable</th>
                                        <th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% offers.forEach(item=>{%>
                                    <tr>
                                        <td class="ps-4 fw-bold"><%=item.offerName%></td>
                                        <td><%= item.itemName%></td>
                                        <td class="text-primary fw-bold"><%= item.discount%>%</td>
                                        <td class="text-muted"><%= item.expiryDate.toISOString().slice(0,10) %></td>
                                        
                                        <td>
                                            <% if(item.isActive){%>
                                            <span class="status-pill status-active">Active</span></td>
                                            <%}else{%>
                                            <span class="status-pill status-disabled">Blocked</span></td>
                                             <%}%>

                                        <td>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" onclick="action('<%= item.targetId%>','<%= item._id%>',this)" name="active" value="<%= item.isActive === true ? false : true%>" type="checkbox" <%= item.isActive ? 'checked' : ''  %> >
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-link text-muted p-0 me-3" onclick="showModal(<%= JSON.stringify(item) %>)" data-bs-toggle="modal" data-bs-target="#editProductOfferModal">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <%})%>
                                </tbody>
                            </table>
                             <div class="d-flex justify-content-end">
          <div class="pagination-container align-items-end">
                        <button onclick="previousPage('<%= page%>')" class="page-link-custom page-arrow"><i class="fa-solid fa-arrow-left"></i></button>
                         <% for(let i = 1; i <= parseInt(count/limit); i++) {%> 
                        <button  id="page" value="<%= i %>" onclick="search(`<%= i %>`)" class="page-link-custom active"><%= i%></button>
                         <% } %>
                        <button onclick="nextPage('<%= page%>')" class="page-link-custom page-arrow"><i class="fa-solid fa-arrow-right"></i></button>
                    </div>
    </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
    </div>

    <div class="modal fade" id="createProductOfferModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold">Create Product Offer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="createFrom" action="product" method="post">
                    <div class="modal-body px-4 pb-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Offer Name</label>
                            <input type="text" class="form-control" name="offerName" placeholder="e.g. Flash Sale" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Select Product</label>
                            <select class="form-select" name="productId" required>
                                <option value="" selected disabled>Choose product...</option>
                                <% products.forEach(product=>{%>
                                     <option  value="<%=product._id%>"><%= product.productName%></option>
                                    <%})%>
                                </select>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Discount (%)</label>
                                <input type="number" class="form-control" name="discount" min="1" max="99" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Expiry Date</label>
                                <input type="date" class="form-control expiryDate" name="expiryDate" required>
                                <p id="expiryError" class="text-danger"></p>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4" style="background-color: var(--primary-blue); border: none;">Create Offer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editProductOfferModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold">Edit Product Offer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form>
                    <input type="hidden" name="offerId" id="editProductOfferId">
                    <div class="modal-body px-4 pb-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Offer Name</label>
                            <input type="text" class="form-control" name="offerName" id="editProductOfferName" required>
                            <p id="offerNameError" class="text-danger"></p>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Discount (%)</label>
                                <input type="number" class="form-control" name="discount" id="editProductOfferDiscount" min="1" max="99" required>
                                <p id="DiscountError" class="text-danger"></p>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Expiry Date</label>
                                <input type="date" class="form-control" name="expiryDate" id="editProductOfferExpiry" required>
                                 <p id="DateError" class="text-danger"></p>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" onclick="update()" class="btn btn-primary px-4" style="background-color: var(--primary-blue); border: none;">Update Offer</button>
                    </div>
                </form>
            </div>
        </div>
               


    </div>
   
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/script/tost.js"></script>
    <script>
        if('<%= success%>'){
                    showToast('Offer updated successfully');
        }

          let correntPage = '<%= page%>';

        function search(page){
          correntPage = page
          window.location.href = `/offers/product?page=${correntPage}`
        }

        function nextPage(correntPgae){
           correntPgae++;
          search(correntPgae)  
             }

        function previousPage(page){
                page--;
                if(page>0){
                     search(page)
                }
             }

             function action(productId,offerId,inputBox){
                
                const data = JSON.stringify({productId,action:inputBox.value,offerId})
                fetch(`/offers/product/action?page=${correntPage}`,{
                    method:"PATCH",
                    headers:{'Content-Type':'application/json'},
                    body:data
                })
                .then((data)=>data.json())
                .then((data=>{
                    if(data?.type === 'error') return showToast(data.message,'error');
                    window.location.href=data.href;
                })).catch(error=>{
                    console.log(error)
                    return showToast('Something was wrong!','error')
                })
             }


             function showModal(offer){
                document.getElementById("editProductOfferName").value=offer.offerName
                document.getElementById("editProductOfferDiscount").value= offer.discount
                document.getElementById("editProductOfferExpiry").value =offer.expiryDate.slice(0,10)
                document.getElementById('editProductOfferId').value = offer._id;
             }

             function update(){
               const offerName =  document.getElementById("editProductOfferName").value
               const discount =   document.getElementById("editProductOfferDiscount").value
               const expiryDate =  document.getElementById("editProductOfferExpiry").value 
               const offerId = document.getElementById('editProductOfferId').value

               if(!offerName){
                document.getElementById('offerNameError').innerText='Offer name required'
                return 
               }
               if(!discount){
                document.getElementById('DiscountError').innerText= "Required"
                return;
               }
               if(discount >99){
                 document.getElementById('DiscountError').innerText= "Invalid Discount"
                 return;
               }
               
               if(new Date(expiryDate)<new Date()){
                document.getElementById('DateError').innerText= "Invalid Date"
                 return;
               }

                const data = JSON.stringify({offerName,discount,expiryDate,offerId})
               fetch('/offers/product/update',{
                method:"PATCH",
                headers:{'Content-Type':'application/json'},
                body:data
               }).then(data=>data.json())
               .then(data=>{
                window.location.reload();
               })
             }



             document.getElementById('createFrom').addEventListener('submit',(e)=>{
                e.preventDefault()
                let flag = true;
                if(new Date(document.querySelector('.expiryDate').value)< new Date()){
                    document.getElementById('expiryError').innerText = "Invaild date";
                    flag = false
                }

                if(flag){
                    document.getElementById('createFrom').submit()
                }
             })

    </script>
</body>
</html>