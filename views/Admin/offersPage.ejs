<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Offer Management - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/adminStyles/sideBar.css">
    <link rel="stylesheet" href="/adminStyles/navBar.css">

    <style>
        :root {
            --sidebar-width: 250px;
            --primary-blue: #4054d2;
            --bg-light: #f5f6fa;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden; 
        }

        #page-content-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            min-height: 100vh;
        }

        /* Offer Choice Cards */
        .offer-selection-card {
            border: none;
            border-radius: 15px;
            background: #fff;
            transition: all 0.3s ease;
            cursor: pointer;
            height: 100%;
            text-align: center;
            padding: 40px 20px;
        }

        .offer-selection-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
            border: 1px solid var(--primary-blue);
        }

        .icon-box {
            width: 80px;
            height: 80px;
            background-color: #f0f2ff;
            color: var(--primary-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 30px;
        }

        .offer-title {
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
        }

        .offer-desc {
            font-size: 0.85rem;
            color: #777;
            margin-bottom: 25px;
        }

        .btn-select {
            border: 1px solid var(--primary-blue);
            color: var(--primary-blue);
            font-weight: 500;
            padding: 8px 25px;
            border-radius: 8px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .offer-selection-card:hover .btn-select {
            background-color: var(--primary-blue);
            color: #fff;
        }
    </style>
</head>
<body>

    <div class="d-flex" id="wrapper">
        <div id="sidebar-wrapper">
            <div class="bg-white h-100 border-end">
                <div class="sidebar-heading text-center py-4 primary-text fs-4 fw-bold text-uppercase">
                    <div class="logo-box d-inline-block me-2">
                        <svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="40" height="36" fill="#F5F5F7"/>
                            <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                        </svg>
                    </div> 
                </div>
                <%- include('../partials/adminSideBar.ejs') %>
            </div>
        </div>

        <div id="page-content-wrapper">
            <%- include('../partials/adminNavBar.ejs') %>

            <div class="container-fluid px-4 pt-5">
                <div class="text-center mb-5">
                    <h3 class="fw-bold">Offer Management</h3>
                    <p class="text-muted">Select the type of offer you want to create or manage</p>
                </div>

                <div class="row g-4 justify-content-center">
                    <div class="col-md-4 col-lg-3">
                        <div class="offer-selection-card shadow-sm" onclick="window.location.href='/offers/category'">
                            <div class="icon-box">
                                <i class="fas fa-layer-group"></i>
                            </div>
                            <h5 class="offer-title">Category Offer</h5>
                            <p class="offer-desc">Apply discounts to entire product categories (e.g., 20% off all Electronics).</p>
                            <span class="btn btn-select">Manage</span>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-3">
                        <div class="offer-selection-card shadow-sm" onclick="window.location.href='/offers/product'">
                            <div class="icon-box">
                                <i class="fas fa-box"></i>
                            </div>
                            <h5 class="offer-title">Product Offer</h5>
                            <p class="offer-desc">Create specific discounts for individual products.</p>
                            <span class="btn btn-select">Manage</span>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-3">
                        <div class="offer-selection-card shadow-sm" onclick="window.location.href='/offers/referral'">
                            <div class="icon-box">
                                <i class="fas fa-user-friends"></i>
                            </div>
                            <h5 class="offer-title">Referral Offer</h5>
                            <p class="offer-desc">Set rewards for users who refer friends to the platform.</p>
                            <span class="btn btn-select">Manage</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>