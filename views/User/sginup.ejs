<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup Page</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<%- include("../partials/navbar") %>
<%- include("../partials/notification.ejs")%>
<section class="py-5">
    <div class="container d-flex justify-content-center">

        <div class="bg-white p-4 rounded shadow-sm" style="max-width:420px; width:100%;">
            <h4 class="mb-4">Signup</h4>

            <form action="/signup" method="post" id="signupForm" novalidate>

                <!-- Username -->
                <label class="form-label">Username *</label>
                <input type="text" name="userName" id="userName" class="form-control mb-1">
                <p class="text-danger small d-none" id="userNameError">
                    Username must be at least 3 characters
                </p>

                <!-- Email -->
                <label class="form-label mt-2">Email *</label>
                <input type="email" name="email" id="email" class="form-control mb-1">
                <p class="text-danger small d-none" id="emailError">
                    Enter a valid email address
                </p>

                <!-- Password -->
                <label class="form-label mt-2">Password *</label>
                <input type="password" name="password" id="password" class="form-control mb-1">
                <p class="text-danger small d-none" id="passwordError">
                    Password must be at least 6 characters
                </p>

                <!-- Confirm Password -->
                <label class="form-label mt-2">Confirm Password *</label>
                <input type="password" name="confirmPassword" id="confirmPassword" class="form-control mb-1">
                <p class="text-danger small d-none" id="confirmPasswordError">
                    Passwords do not match
                </p>

                <!-- Phone -->
                <label class="form-label mt-2">Phone Number (Optional)</label>
                <input type="text" name="phoneNumber" id="phoneNumber" class="form-control mb-1">
                <p class="text-danger small d-none" id="phoneError">
                    Phone number must be 10 digits
                </p>

                <!-- Submit -->
                <button type="submit" class="btn btn-primary w-100 my-3">
                    Signup
                </button>

                <!-- Referral -->
                <label class="form-label">Referral Code (Optional)</label>
                <input type="text" name="referralCode" class="form-control mb-3">

                <p class="small text-center">
                    Already have an account? <a href="/login">Login Here</a>
                </p>

                <a href="/google/login" type="button" class="btn btn-outline-secondary w-100">
                    Continue with Google
            </a>

            </form>
        </div>
    </div>
</section>

<%- include("../partials/footer") %>

<!-- Validation Script -->
<script>
document.getElementById("signupForm").addEventListener("submit", function (e) {
    let valid = true;

    const userName = document.getElementById("userName");
    const email = document.getElementById("email");
    const password = document.getElementById("password");
    const confirmPassword = document.getElementById("confirmPassword");
    const phone = document.getElementById("phoneNumber");

    // Username
    if (userName.value.trim().length < 3) {
        document.getElementById("userNameError").classList.remove("d-none");
        valid = false;
    } else {
        document.getElementById("userNameError").classList.add("d-none");
    }

    // Email
    if (!email.value.includes("@")) {
        document.getElementById("emailError").classList.remove("d-none");
        valid = false;
    } else {
        document.getElementById("emailError").classList.add("d-none");
    }

    // Password
    if (password.value.length < 6) {
        document.getElementById("passwordError").classList.remove("d-none");
        valid = false;
    } else {
        document.getElementById("passwordError").classList.add("d-none");
    }

    // Confirm password
    if (password.value !== confirmPassword.value) {
        document.getElementById("confirmPasswordError").classList.remove("d-none");
        valid = false;
    } else {
        document.getElementById("confirmPasswordError").classList.add("d-none");
    }

    // Phone (optional)
    if (phone.value && !/^\d{10}$/.test(phone.value)) {
        document.getElementById("phoneError").classList.remove("d-none");
        valid = false;
    } else {
        document.getElementById("phoneError").classList.add("d-none");
    }

    if (!valid) {
        e.preventDefault(); // stop form submit
    }
});
</script>

</body>
</html>
