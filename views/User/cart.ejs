<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body { background-color: #f4f6f9; font-family: sans-serif; }
        .cart-container { padding-top: 50px; }
        
        /* Table Styling */
        .table thead th { 
            background-color: #f8f9fa; 
            text-transform: capitalize; 
            color: #6c757d; 
            font-weight: 500;
            border-bottom: 1px solid #dee2e6;
        }
        .product-img { width: 50px; height: auto; border-radius: 4px; }
        .old-price { text-decoration: line-through; color: #adb5bd; margin-right: 8px; }
        
        /* Quantity Counter */
        .quantity-group { width: 130px; }
        .btn-qty { border: 1px solid #dee2e6; background: #fff; font-weight: bold; }
        
        /* Summary Card */
        .card-totals { border: none; border-radius: 8px; }
        .btn-checkout { background-color: #4054d2; border: none; font-weight: 600; padding: 12px; }
        .btn-checkout:hover { background-color: #3444b0; }
        
        /* Coupon Section */
        .coupon-card { border: none; border-radius: 8px; }
        .btn-apply { border: 1px solid #4054d2; color: #4054d2; font-weight: 500; }
        .btn-apply:hover { background-color: #4054d2; color: #fff; }
         .btn-disabled {
            
            background-color: #f2f2f2;
            color: #333;
            text-decoration: line-through;
            font-weight: 600;
            border: none;
            padding: 8px 25px;
            border-radius: 6px;
            font-size: 0.85rem;
            width: 140px;
            cursor: not-allowed !important;
        }
    </style>
</head>
<body>
<%- include('../partials/navbar.ejs') %>
<%- include('../partials/notification.ejs')%>
<div class="container cart-container">
    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-0">
                    <h5 class="p-4 mb-0 fw-bold">Shopping Cart</h5>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Products</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Sub-Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% cartItems.forEach((value)=>{ %>
                                <tr id="row">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <button onclick="deleteCart(`<%= value._id%>`)" class="btn btn-sm text-muted me-3"><i class="bi bi-x-circle fs-5"></i></button>
                                            <img src="<%= value.product.generalPhoto.url %>" class="product-img me-3" alt="Laptop">
                                            <span class="text-truncate" style="max-width: 150px;"><%= value.product.productName%></span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="old-price">₹<%= value.product.variants.price%></span>
                                        <span class="fw-bold">₹<%=  parseInt(value.finalPrice).toLocaleString('en-IN')%></span>
                                    </td>
                                    <td>
                                        <div id="cartItem" class="input-group quantity-group">
                                            <form action="/cart" method="post">
                                                <!-- <input type="hidden" name="decrement" value="decrement"> -->
                                                <input type="hidden" name="productId" value="<%= value.productId %>">
                                                <input type="hidden" name="quantity" value="<%= value.quantity%>">
                                                <input type="hidden" name="variantId" value="<%= value.variantId %>">
                                             
                                            <button  type="button" onclick="decrement(`<%= value.product.variants.stock%>`,`<%= value.productId %>`,`<%= value.variantId %>`,this,`<%=  value.finalPrice%>`)" class="decrementButton btn btn-qty">-</button>
                                            </form>
                                            <input type="text" class="form-control text-center bg-white quantityInput"  value="<%= value.quantity%>" readonly>
                                            <form action="/cart" method="post">
                                                <!-- <input type="hidden" value="increment"> -->
                                                <input type="hidden" name="productId" value="<%= value.productId %>">
                                                <input type="hidden" name="quantity" value="<%= value.quantity%>">
                                                <input type="hidden" name="variantId" value="<%= value.variantId %>">
                                                
                                            <button  type="button" onclick="increment(`<%= value.product.variants.stock%>`,`<%= value.productId %>`,`<%= value.variantId %>`,this,`<%=  value.finalPrice%>`)" class="incrementButton btn btn-qty ">+</button>
                                            </form>
                                        </div>
                                    </td>
                                     
                                    <td class="fw-bold border-bottom-0 subTotalPrice">₹<%=  parseInt(value.finalPrice*value.quantity).toLocaleString('en-IN')%></td>
                                </tr>
                                <% })%>
                                 <tr>
                                    <td>
                                 <a href="/deleteCartItems" class="btn btn-danger <%= cartItems?.length >0?'d-block':'d-none'%>">Clear</a>
                                 </td>
                                 </tr>
                            </tbody>

                           
                        </table>
                         
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card card-totals shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Cart Totals</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Sub-total (Before Discounts)</span>
                        <span id="subTotal"  class="fw-bold">₹<%= subTotal.totalPriceCartItem.toLocaleString('en-IN')%></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total Discount price</span>
                        <span id="discount"  class="fw-bold">₹<%= subTotal.totalDiscountPrice.toLocaleString('en-IN')%></span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-muted">GST </span>
                        <span id="tax" class="fw-bold">₹<%= subTotal.tax%></span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="h5 fw-bold mb-0">Total</span>
                        <span id="total" class="h5 fw-bold mb-0">₹<%= subTotal.total.toLocaleString('en-IN')%> </span>
                    </div>
                       <%if(cartItems.length < 1 ){%>
                     <a href="" class="btn btn-disabled w-100 text-decoration-line-through ">PROCEED TO CHECKOUT</a>
                     <%}else{%>
                    <a href="/checkout" class="btn btn-primary w-100 btn-checkout">PROCEED TO CHECKOUT</a>
                    <%}%>
                </div>
            </div>

           
    </div>
</div>
<script>
    let stockValue;
    let click;
     document.getElementById('row').addEventListener('click',(e)=>{
        click = e;
        
     })
     function decrement(stock,productId,variantId,element,price){
         const container = element.closest('.quantity-group');
         const row = element.closest("tr")
        const qtyInput = container.querySelector('.quantityInput');
        const subTotalPrice = row.querySelector('.subTotalPrice')


        stockValue = stock
        let quantityInput=  qtyInput.value;
        if(Number(quantityInput) >1){
        fetch('/cart',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({quantity:Number(quantityInput),productId,variantId,decrement:"decrement"})
        }).then(data=>data.json())
        .then((data)=>{
            if(data.type === 'error'){
                window.location.reload();
            }
 
           qtyInput.value =quantityInput-1;
            stockValue = data.stock
            console.log(data)
            const  total =  Number(quantityInput-1)*Number(price)
            subTotalPrice.innerText = `₹${total.toLocaleString('en-IN')}`
            
             document.getElementById('subTotal').innerText = `₹${data.subTotal.totalPriceCartItem.toLocaleString('en-IN')}`
             document.getElementById('discount').innerText = `₹${data.subTotal.totalDiscountPrice.toLocaleString('en-IN')}`
             document.getElementById('tax').innerText = `₹${data.subTotal.tax.toLocaleString('en-IN')}`
              document.getElementById('total').innerText = `₹${data.subTotal.total.toLocaleString('en-IN')}`
        })
        .catch(error=>{

        })
         }
    }


    function increment(stock,productId,variantId,element,price){
         const container = element.closest('.quantity-group');
         const row = element.closest("tr")
        const qtyInput = container.querySelector('.quantityInput');
        const subTotalPrice = row.querySelector('.subTotalPrice')
        stockValue = stock
        console.log(stockValue)
       let quantityInput=   qtyInput.value;
       quantityInput = Number(quantityInput);
       quantityInput++
       console.log(quantityInput)
        if(Number(quantityInput) <= stockValue &&Number(quantityInput) <= 5){
        fetch('/cart',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({quantity:Number(quantityInput),productId,variantId,increment:"increment"})
        }).then(data=>data.json())
        .then((data)=>{

            if(data.type === 'error'){
                window.location.reload();
            }
             qtyInput.value = quantityInput;
            stockValue = data.stock
            console.log(data)
            const  total =  Number(quantityInput)*Number(price)
            subTotalPrice.innerText = `₹${total.toLocaleString('en-IN')}`
            document.getElementById('subTotal').innerText = `₹${data.subTotal.totalPriceCartItem.toLocaleString('en-IN')}`
             document.getElementById('discount').innerText = `₹${data.subTotal.totalDiscountPrice.toLocaleString('en-IN')}`
             document.getElementById('tax').innerText = `₹${data.subTotal.tax.toLocaleString('en-IN')}`
              document.getElementById('total').innerText = `₹${data.subTotal.total.toLocaleString('en-IN')}`
            
            
            

        })
        .catch(error=>{
            console.log(error);
            showToast("Something was wrong");
        })
         }else{
            showToast(`Only ${stock} stock is available`,'error')
         }
    }






    
    function deleteCart(_id){
           if(confirm("Are you shure about remove from cart?")) {
            fetch('/cart',{
                method:"DELETE",
                headers:{"Content-Type":"application/json"},
                body:JSON.stringify({_id})
            })
            .then(data=>data.json())
            .then(data=>{
                if(data.success){
                    window.location.href= data.href
                }
                if(!data.success){
                    console.log(data.message)
                }
            })
           }
            
    }



   
  
</script>
<script src="/script/tost.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>