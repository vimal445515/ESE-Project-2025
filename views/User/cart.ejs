<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body { background-color: #f4f6f9; font-family: sans-serif; }
        .cart-container { padding-top: 50px; }
        
        /* Table Styling */
        .table thead th { 
            background-color: #f8f9fa; 
            text-transform: capitalize; 
            color: #6c757d; 
            font-weight: 500;
            border-bottom: 1px solid #dee2e6;
        }
        .product-img { width: 50px; height: auto; border-radius: 4px; }
        .old-price { text-decoration: line-through; color: #adb5bd; margin-right: 8px; }
        
        /* Quantity Counter */
        .quantity-group { width: 130px; }
        .btn-qty { border: 1px solid #dee2e6; background: #fff; font-weight: bold; }
        
        /* Summary Card */
        .card-totals { border: none; border-radius: 8px; }
        .btn-checkout { background-color: #4054d2; border: none; font-weight: 600; padding: 12px; }
        .btn-checkout:hover { background-color: #3444b0; }
        
        /* Coupon Section */
        .coupon-card { border: none; border-radius: 8px; }
        .btn-apply { border: 1px solid #4054d2; color: #4054d2; font-weight: 500; }
        .btn-apply:hover { background-color: #4054d2; color: #fff; }
         .btn-disabled {
            
            background-color: #f2f2f2;
            color: #333;
            text-decoration: line-through;
            font-weight: 600;
            border: none;
            padding: 8px 25px;
            border-radius: 6px;
            font-size: 0.85rem;
            width: 140px;
            cursor: not-allowed !important;
        }
    </style>
</head>
<body>
<%- include('../partials/navbar.ejs') %>

<div class="container cart-container">
    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-0">
                    <h5 class="p-4 mb-0 fw-bold">Shopping Card</h5>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Products</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Sub-Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% cartItems.forEach((value)=>{ %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <button onclick="deleteCart(`<%= value._id%>`)" class="btn btn-sm text-muted me-3"><i class="bi bi-x-circle fs-5"></i></button>
                                            <img src="/upload/<%= value.product.generalPhoto%>" class="product-img me-3" alt="Laptop">
                                            <span class="text-truncate" style="max-width: 150px;"><%= value.product.productName%></span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="old-price">₹<%= value.product.variants.price%></span>
                                        <span class="fw-bold">₹<%=  value.product.variants.price-parseInt((value.product.discound/100)*value.product.variants.price)%></span>
                                    </td>
                                    <td>
                                        <div class="input-group quantity-group">
                                            <form action="/cart" method="post">
                                                <input type="hidden" name="decrement" value="decrement">
                                                <input type="hidden" name="productId" value="<%= value.productId %>">
                                                <input type="hidden" name="quantity" value="<%= value.quantity%>">
                                                <input type="hidden" name="variantId" value="<%= value.variantId %>">
                                               
                                            <button  type="submit" class="decrementButton btn btn-qty">-</button>
                                            </form>
                                            <input type="text" class="form-control text-center bg-white" value="<%= value.quantity%>" readonly>
                                            <form action="/cart" method="post">
                                                <input type="hidden" value="increment">
                                                <input type="hidden" name="productId" value="<%= value.productId %>">
                                                <input type="hidden" name="quantity" value="<%= value.quantity%>">
                                                <input type="hidden" name="variantId" value="<%= value.variantId %>">
                                                
                                            <button  type="submit" class="incrementButton btn btn-qty ">+</button>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="fw-bold border-bottom-0">₹<%=  (value.product.variants.price-parseInt((value.product.discound/100)*value.product.variants.price))*value.quantity%></td>
                                </tr>
                                <% })%>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card card-totals shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Cart Totals</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Sub-total</span>
                        <span class="fw-bold">₹<%= subTotal.totalPriceCartItem%></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Discount</span>
                        <span class="fw-bold">₹<%= subTotal.totalDiscountPrice%></span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-muted">Tax</span>
                        <span class="fw-bold">₹<%= subTotal.tax%></span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="h5 fw-bold mb-0">Total</span>
                        <span class="h5 fw-bold mb-0">₹<%= subTotal.total%> INR</span>
                    </div>
                       <%if(cartItems.length < 1 ){%>
                     <a href="" class="btn btn-disabled w-100 text-decoration-line-through ">PROCEED TO CHECKOUT</a>
                     <%}else{%>
                    <a href="/checkout" class="btn btn-primary w-100 btn-checkout">PROCEED TO CHECKOUT</a>
                    <%}%>
                </div>
            </div>

            <div class="card coupon-card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Coupon Code</h5>
                    <div class="mb-3">
                        <input type="text" class="form-control p-3" placeholder="Coupon code">
                    </div>
                    <button class="btn btn-apply px-4 py-2">APPLY COUPON</button>
                </div>
            </div>
        </div>

    </div>
</div>
<script>
    function deleteCart(_id){
           if(confirm("Are you shure about remove from cart?")) {
            fetch('/cart',{
                method:"DELETE",
                headers:{"Content-Type":"application/json"},
                body:JSON.stringify({_id})
            })
            .then(data=>data.json())
            .then(data=>{
                if(data.success){
                    window.location.href= data.href
                }
                if(!data.success){
                    console.log(data.message)
                }
            })
           }
            
    }

