<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Samsung Product Landing - Exact</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/userStyles/home.css">
    
</head>
<body>
    <%- include("../partials/navbar") %>
    <section class="top-hero">
        <div class="container">
            <div class="hero-content">
                <h1>Explore Most <br>Affordable <br>samsung <br>products</h1>
                <p>Samsung isn't just about individual devices. It's about how they all work together to make life easier.</p>
            </div>
            <div class="hero-image-placeholder">
                <img src="" alt="Phone Hero">
            </div>
        </div>
    </section>

    <section class="ecosystem py-5 text-center">
        <h2 class="section-heading mb-5">Samsung Echo System</h2>
        <div class="d-flex justify-content-center gap-5 flex-wrap">
          <% data.forEach((category)=>{ %>
              <div class="eco-item">
                <div class="icon-box"><img src="<%= category.thumbnail%>" alt="Phone"></div>
                <span><%= category.categoryName %></span>
            </div>
        <%})%>
        </div>
    </section>

    <section class="mid-hero position-relative">
        <img src="/demoimg/002-lifestyle-galaxy-buds3-FE-black-horizontal.jpg" class="mid-hero-bg" alt="Banner">
        <div class="mid-hero-overlay">
            <div class="promo-text">
                <h3><i class="fa-solid fa-arrow-right-long me-2"></i> SES</h3>
                <p class="small-text">From ₹3000 to ₹10,000. Every product</p>
                <div class="mt-3">
                    <button class="btn btn-primary me-3">Buy</button>
                </div>
            </div>
            
        
        </div>
    </section>

    <section class="product-collection py-5 bg-white">
        <div class="container position-relative">
            <h2 class="section-heading text-center mb-5">Newest Ses Collection</h2>
            
           <button id="left" class="nav-arrow prev-arrow"><i class="fa-solid fa-chevron-left"></i></button>
            <button id="right" class="nav-arrow next-arrow"><i class="fa-solid fa-chevron-right"></i></button>
           
            <div class="product-slider">
                <%newProducts.forEach((product)=>{%>
                <div class="product-card">
                    <span class="badge-new">New</span>
                    <img src="upload/<%= product.generalPhoto%>" alt="<%= product.productName%>" class="img-fluid product-img">
                    <h5><%= product.productName%></h5>
                    <p class="price">₹<%= product.basePrice %></p>
                    <button class="btn-buy-full">Buy</button>
                </div> 
                <%})%>
            </div>
    
        </div>
    </section>

    <section class="banner-section py-5">
        <div class="container">
            <div class="black-banner">
                <h2 class="watch-title">Galaxy Watch</h2>
            </div>
        </div>
    </section>

    <section class="product-collection py-5 bg-white">
        <div class="container position-relative">
            
            <button id="left" class="nav-arrow prev-arrow"><i class="fa-solid fa-chevron-left"></i></button>
            <button id="right" class="nav-arrow next-arrow"><i class="fa-solid fa-chevron-right"></i></button>

            <div class="product-slider">
                <% watches.forEach((watch)=>{%>
                <div class="product-card">
                    <img src="upload/<%= watch.generalPhoto%>" alt="<%= watch.productName%>" class="img-fluid product-img rounded-circle">
                    <h5><%= watch.productName%></h5>
                    <p class="price">₹<%= watch.basePrice%></p>
                    <button class="btn-buy-full">Buy</button>
                </div>
                <%})%>
            </div>
        </div>
    </section>
    <%- include("../partials/footer.ejs")%>
</body>
    <script>
    const slider = document.querySelector(".product-slider");
    const nextBtn = document.querySelector(".next-arrow");
    const prevBtn = document.querySelector(".prev-arrow");

    const scrollAmount = 250;

    nextBtn.addEventListener("click", () => {
        slider.scrollLeft += scrollAmount;
    });

    prevBtn.addEventListener("click", () => {
        slider.scrollLeft -= scrollAmount;
    });
</script>

    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</html>