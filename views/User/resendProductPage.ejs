<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cancel Order - Samsung Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --primary-blue: #4054d2;
        }
        body { 
            background-color: #f8f9fa; 
            font-family: 'Inter', sans-serif; 
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        
        /* Ensures footer stays at bottom */
        .main-wrapper {
            flex: 1;
            display: flex;
            align-items: center;
            padding: 60px 0;
        }

        /* Cancellation Form Styling */
        .cancel-title { font-weight: 800; font-size: 2.2rem; color: #000; margin-bottom: 5px; }
        .cancel-subtitle { color: #f1f3f5; position: absolute; font-weight: 800; font-size: 2.2rem; z-index: -1; top: -5px; }
        .reason-box { border: 1px solid #dee2e6; border-radius: 6px; min-height: 200px; padding: 15px; transition: border-color 0.3s; }
        .reason-box:focus { border-color: var(--primary-blue); box-shadow: none; }
        .btn-confirm { background-color: var(--primary-blue); border: none; padding: 12px 40px; font-weight: 600; border-radius: 8px; }

        /* Contact Info Card Styling */
        .contact-card { 
            background-color: #000; 
            color: #fff; 
            border-radius: 15px; 
            padding: 45px; 
            position: relative; 
            overflow: hidden;
            min-height: 520px;
        }
        .contact-card h3 { font-weight: 700; margin-bottom: 12px; }
        .contact-card p { color: #adb5bd; font-size: 0.95rem; margin-bottom: 45px; }
        
        .info-item { display: flex; align-items: center; margin-bottom: 35px; font-size: 0.95rem; }
        .info-item i { margin-right: 18px; font-size: 1.3rem; color: #fff; }

        /* Decorative elements */
        .circle-1 { position: absolute; width: 140px; height: 140px; background: rgba(255,255,255,0.08); border-radius: 50%; bottom: 40px; right: 70px; }
        .circle-2 { position: absolute; width: 180px; height: 180px; background: rgba(255,255,255,0.04); border-radius: 50%; bottom: -50px; right: -30px; }

        /* Social Icons */
        .social-links { display: flex; gap: 15px; margin-top: 60px; }
        .social-btn { 
            width: 40px; 
            height: 40px; 
            background: #212529; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            border-radius: 50%; 
            color: #fff; 
            text-decoration: none;
            transition: 0.3s;
        }
        .social-btn:hover { background: var(--primary-blue); transform: translateY(-3px); }
    </style>
</head>
<body>

<%- include("../partials/navbar.ejs") %>

<div class="main-wrapper">
    <div class="container">
        <div class="row align-items-center justify-content-center g-5">
            
            <div class="col-lg-5 order-2 order-lg-1">
                <div class="position-relative mb-4">
                    <h1 class="cancel-title">Why do you return this product?</h1>
                    <div class="cancel-subtitle">Why do you Resend the product?</div>
                </div>
                
                <form action="/orders/return" method="POST">
                    <div class="mb-4">
                        <input type="hidden" name="orderId" value="<%= orderId%>">
                        <label class="form-label fw-bold mb-2">Reason</label>
                        <textarea name="reason" class="form-control reason-box" placeholder="Please describe why you are cancelling your order..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-confirm shadow-sm">Confirm</button>
                </form>
            </div>

            <div class="col-lg-5 order-1 order-lg-2">
                <div class="contact-card shadow-lg">
                    <h3>Contact Information</h3>
                    <p>Have questions about your order? Start a live chat with our support team.</p>
                    
                    <div class="info-item">
                        <i class="bi bi-telephone-fill"></i>
                        <span>+91 9778238495</span>
                    </div>
                    
                    <div class="info-item">
                        <i class="bi bi-envelope-fill"></i>
                        <span>chateesamsung@gmail.com</span>
                    </div>
                    
                    <div class="info-item">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span>INDIA, KERALA, KOCHI, SES_store</span>
                    </div>

                    <div class="social-links">
                        <a href="#" class="social-btn" title="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-btn" title="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-btn" title="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="social-btn" title="Twitter"><i class="bi bi-twitter-x"></i></a>
                    </div>

                    <div class="circle-1"></div>
                    <div class="circle-2"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<% if (popup) { %>
<div class="modal fade" id="popupModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-<%= popup.type === 'success' ? 'success' : 'danger' %> text-white">
        <h5 class="modal-title">Message</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p><%= popup.message %></p>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = new bootstrap.Modal(document.getElementById('popupModal'));
  modal.show();
</script>
<% } %>



<%- include("../partials/footer.ejs") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>