<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Failed</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-blue: #4054d2;
            --error-red: #e74c3c;
            --bg-light: #f5f6fa;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Poppins', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .main-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .failure-card {
            max-width: 500px;
            width: 100%;
            background: #fff;
            padding: 50px 40px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: center;
        }

        .error-container {
            width: 80px;
            height: 80px;
            background-color: #fdeaea;
            color: var(--error-red);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            font-size: 2.5rem;
        }

        .error-message-box {
            background-color: #fff5f5;
            padding: 12px 20px;
            border-radius: 12px;
            font-size: 0.9rem;
            color: #c0392b;
            border: 1px solid #fadbd8;
            margin-bottom: 30px;
        }

        .btn-retry {
            background-color: var(--primary-blue);
            color: #fff !important;
            padding: 12px 30px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: 0.3s;
            border: none;
            width: 100%;
        }

        .btn-retry:hover {
            background-color: #3344aa;
            transform: translateY(-2px);
        }

        .btn-cart {
            color: #888;
            font-size: 0.9rem;
            text-decoration: none;
            margin-top: 20px;
            display: inline-block;
        }

        .support-text {
            font-size: 0.85rem;
            color: #999;
            margin-top: 25px;
        }
    </style>
</head>
<body>

    <%- include('../partials/navbar.ejs') %>

    <div class="main-content">
        <div class="failure-card">
            <div class="error-container">
                <i class="fas fa-times-circle"></i>
            </div>
            
            <h2 class="fw-bold mb-2">Payment Failed</h2>
            <p class="text-muted mb-4">Oops! Something went wrong while processing your order. No funds were captured.</p>
            
            <div class="error-message-box">
                <strong>Reason:<%= reason%></strong> %>
            </div>

            <div class="mt-2">
                <button onclick="payNow()"  class="btn-retry">
                    <i class="fas fa-redo me-2"></i> Try Payment Again
                </button>
            </div>

            <a href="/orders/orderDetails/<%= productOrderId%>" class="btn-cart">
                <i class="fas fa-shopping-cart me-1"></i> View order Details
            </a>

            <div class="support-text">
                Need help? <a href="/contact" class="text-decoration-none">Contact Support</a>
            </div>
        </div>
    </div>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
    async function payNow(){

          console.log('<%= orderId%>')
          const res = await   fetch('/oldOrderId',{
                method:"POST",
                headers:{'Content-type':'application/json'},
                body:JSON.stringify({paymentOrderId:'<%= orderId%>'})
            })
     const order = await res.json();
    let options = {
    key:order.keyId,
    amount: order.amount,
    currency: "INR",
    order_id: order.paymentOrderId,
    name: "SES",
    handler: function (response) {
      fetch('/varifyPayment',{
        method:'POST',
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify(response)
      }).then(data=>data.json())
      .then(data=>{
        if(data.type === "success"){
            window.location.href=data.href;
        }
        if(data.type === "error"){
            window.location.href=data.href
        }
      })
    }
  };

  let rzp1 = new Razorpay(options);
  rzp1.open();

  rzp1.on('payment.failed',function (response){
   
    fetch('/paymentFaild',{
        method:"POST",
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({orderId:response.error.metadata.order_id,reson:response.error.reason})
    }).then(data=>data.json())
    .then(data=>{
        if(data.type === "error"){
            window.location.href=data.href;
        }
    })
  })
    }
</script>
</body>
</html>