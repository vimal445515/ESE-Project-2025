<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Placed Successfully</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-blue: #4054d2;
            --success-green: #1A9882;
            --bg-light: #f5f6fa;
        }

        body { 
            background-color: var(--bg-light); 
            font-family: 'Poppins', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column; /* Stack navbar on top of content */
        }

        /* Container to center the card */
        .main-content {
            flex: 1; /* Takes up all remaining height */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .success-card {
            max-width: 500px;
            width: 100%;
            background: #fff;
            padding: 50px 40px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: center;
        }

        .check-container {
            width: 80px;
            height: 80px;
            background-color: #E9FAF7;
            color: var(--success-green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            font-size: 2.5rem;
        }

        .order-id-label {
            background-color: #f1f3f5;
            padding: 8px 20px;
            border-radius: 30px;
            font-size: 0.9rem;
            color: #666;
            display: inline-block;
            margin-bottom: 30px;
        }

        .btn-details {
            background-color: var(--primary-blue);
            color: #fff !important;
            padding: 12px 30px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: 0.3s;
            border: none;
            width: 100%;
        }

        .btn-details:hover {
            background-color: #3344aa;
            transform: translateY(-2px);
        }

        .btn-home {
            color: #888;
            font-size: 0.9rem;
            text-decoration: none;
            margin-top: 20px;
            display: inline-block;
        }
    </style>
</head>
<body>

    <%- include('../partials/navbar.ejs') %>

    <div class="main-content">
        <div class="success-card">
            <div class="check-container">
                <i class="fas fa-check-circle"></i>
            </div>
            
            <h2 class="fw-bold mb-2">Order Placed!</h2>
            <p class="text-muted mb-4">Your order has been successfully placed. You will receive a confirmation email shortly.</p>
            
            <div class="order-id-label">
                Order ID: <strong><%= orderId%></strong>
            </div>

            <div class="mt-2">
                <a href="orders/orderDetails/<%= orderId%>" class="btn-details">
                    <i class="fas fa-list-ul me-2"></i> View Order Details
                </a>
            </div>

            <a href="/products" class="btn-home">
                <i class="fas fa-arrow-left me-1"></i> Continue Shopping
            </a>
        </div>
    </div>

</body>
</html>