<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - SES</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/userStyles/home.css">
    <style>
        .contact-section { padding: 80px 0; background-color: #f8f9fa; }
        .contact-card { display: flex; border-radius: 15px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); background: white; }
        .contact-info { background: #000; color: white; padding: 40px; width: 40%; position: relative; }
        .contact-form-container { padding: 40px; width: 60%; }
        .info-item { display: flex; align-items: center; margin-bottom: 25px; gap: 15px; }
        .circle-decoration { position: absolute; bottom: -20px; right: -20px; width: 150px; height: 150px; background: rgba(255,255,255,0.1); border-radius: 50%; }
        .btn-send { background: #4e6bff; color: white; border: none; padding: 10px 30px; border-radius: 5px; width: 100%; }
    </style>
</head>
<body>
    <%- include("../partials/navbar") %>
    <%- include('../partials/notification')%>
    <section class="contact-section">
        <div class="container">
            <div class="contact-card">
                <div class="contact-info">
                    <h3>Contact Information</h3>
                    <p class="text-secondary mb-5">Say something to start a live chat!</p>
                    
                    <div class="info-item">
                        <i class="fa-solid fa-phone"></i>
                        <span>+91 9778238495</span>
                    </div>
                    <div class="info-item">
                        <i class="fa-solid fa-envelope"></i>
                        <span>eseproject2025@gamil.com</span>
                    </div>
                    <div class="info-item">
                        <i class="fa-solid fa-location-dot"></i>
                        <span>INDIA, KERALA, KOCHI, SES_STORE</span>
                    </div>

                    <div class="social-links mt-5 pt-5">
                        <i class="fab fa-facebook-f me-3"></i>
                        <i class="fab fa-instagram me-3"></i>
                        <i class="fab fa-youtube me-3"></i>
                        <i class="fab fa-twitter"></i>
                    </div>
                    <div class="circle-decoration"></div>
                </div>

                <div class="contact-form-container">
                    <form action="/contact" method="POST" id="form">
                        <div class="row g-3 mb-4">
                            <div class="col">
                                <label class="form-label small text-muted">Name</label>
                                <input type="text" class="form-control border-0 border-bottom" name="name">
                                <p id="nameError" class="text-danger"></p>
                            </div>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col">
                                <label class="form-label small text-muted">Email</label>
                                <input type="email" class="form-control border-0 border-bottom" name="email">
                                 <p id="emailError" class="text-danger"></p>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label d-block small text-muted">Select Subject?</label>
                            <div class="form-label text-muted ">
                                <input class="form-control border-0 border-bottom" type="text" name="subject" >
                                 <p id="subjectError" class="text-danger"></p>
                            </div>
                            </div>
                        <div class="mb-4">
                            <label class="form-label small text-muted">Message</label>
                            <textarea class="form-control border-0 border-bottom" name="message" placeholder="Write your message.."></textarea>
                             <p id="messageError" class="text-danger"></p>
                        </div>
                        <button type="submit" class="btn btn-primary">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
    <%- include("../partials/footer") %>

    <script>
        const form = document.querySelector("#form");
        form.addEventListener('submit',(e)=>{
            e.preventDefault()

             
    document.getElementById("nameError").innerText = "";
    document.getElementById("emailError").innerText = "";
    document.getElementById("subjectError").innerText = "";
    document.getElementById("messageError").innerText = "";

    let valid = true;

    const name = form.name.value.trim();
    const email = form.email.value.trim();
    const subject = form.subject.value.trim();
    const message = form.message.value.trim();

   
    if (!name) {
        document.getElementById("nameError").innerText = "Name is required";
        valid = false;
    }

    
    if (!email || !email.includes("@") || !email.includes(".")) {
        document.getElementById("emailError").innerText = "Enter a valid email";
        valid = false;
    }

   
    if (!subject) {
        document.getElementById("subjectError").innerText = "Subject is required";
        valid = false;
    }

 
    if (!message || message.length < 5) {
        document.getElementById("messageError").innerText = "Message must be at least 5 characters";
        valid = false;
    }

    if(!valid) return

            const formData = {
                email:form.email.value,
                name:form.name.value,
                subject:form.subject.value,
                message:form.message.value
            }

            fetch('/contact',{
                method:"POST",
                headers:{"Content-Type":"application/json"},
                body:JSON.stringify(formData)
            })
            .then(data=>data.json())
            .then(data=>{
               form.email.value=""
                form.name.value=''
               form.subject.value=''
               form.message.value=''
                if(data.type== "success"){
                    showToast(data.message)
                }else if( data.type =="error"){

                    showToast(data.message,'error')
                }
            }).catch((error)=>{
                console.log(error)
                showToast("somthing was wrong we can't send data",'error');
            })
        })
    </script>
    <script src="/script/tost.js"></script>
</body>
</html>