<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - SES</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/userStyles/home.css">
    <style>
        .contact-section { padding: 80px 0; background-color: #f8f9fa; }
        .contact-card { display: flex; border-radius: 15px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); background: white; }
        .contact-info { background: #000; color: white; padding: 40px; width: 40%; position: relative; }
        .contact-form-container { padding: 40px; width: 60%; }
        .info-item { display: flex; align-items: center; margin-bottom: 25px; gap: 15px; }
        .circle-decoration { position: absolute; bottom: -20px; right: -20px; width: 150px; height: 150px; background: rgba(255,255,255,0.1); border-radius: 50%; }
        .btn-send { background: #4e6bff; color: white; border: none; padding: 10px 30px; border-radius: 5px; width: 100%; }
    </style>
</head>
<body>
    <%- include("../partials/navbar") %>

    <section class="contact-section">
        <div class="container">
            <div class="contact-card">
                <div class="contact-info">
                    <h3>Contact Information</h3>
                    <p class="text-secondary mb-5">Say something to start a live chat!</p>
                    
                    <div class="info-item">
                        <i class="fa-solid fa-phone"></i>
                        <span>+91 9778238495</span>
                    </div>
                    <div class="info-item">
                        <i class="fa-solid fa-envelope"></i>
                        <span>eseproject2025@gamil.com</span>
                    </div>
                    <div class="info-item">
                        <i class="fa-solid fa-location-dot"></i>
                        <span>INDIA, KERALA, KOCHI, SES_STORE</span>
                    </div>

                    <div class="social-links mt-5 pt-5">
                        <i class="fab fa-facebook-f me-3"></i>
                        <i class="fab fa-instagram me-3"></i>
                        <i class="fab fa-youtube me-3"></i>
                        <i class="fab fa-twitter"></i>
                    </div>
                    <div class="circle-decoration"></div>
                </div>

                <div class="contact-form-container">
                    <form action="/contact" method="POST">
                        <div class="row g-3 mb-4">
                            <div class="col">
                                <label class="form-label small text-muted">First Name</label>
                                <input type="text" class="form-control border-0 border-bottom" placeholder="Vimal">
                            </div>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col">
                                <label class="form-label small text-muted">Email</label>
                                <input type="email" class="form-control border-0 border-bottom" placeholder="example@gmail.com">
                            </div>
                            <div class="col">
                                <label class="form-label small text-muted">Phone Number</label>
                                <input type="text" class="form-control border-0 border-bottom" placeholder="+91">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label d-block small text-muted">Select Subject?</label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="subject" checked>
                                <label class="form-check-label">General Inquiry</label>
                            </div>
                            </div>
                        <div class="mb-4">
                            <label class="form-label small text-muted">Message</label>
                            <textarea class="form-control border-0 border-bottom" placeholder="Write your message.."></textarea>
                        </div>
                        <button type="submit" class="btn btn-send">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <%- include("../partials/footer") %>
</body>
</html>