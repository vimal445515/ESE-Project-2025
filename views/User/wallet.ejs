                                    <td>-</td>
                                </tr>

                                <tr>
                                    <td>#96459759</td>
                                    <td>Bought a product</td>
                                    <td>Dec 30, 2023</td>
                                    <td>-</td>
                                    <td>₹ 36000</td>
                                </tr>

                                <tr>
                                    <td>#96459758</td>
                                    <td>You added</td>
                                    <td>Dec 30, 2023</td>
                                    <td>₹ 12,000</td>
                                    <td>-</td>
                                </tr>

                                <tr>
                                    <td>#96459757</td>
                                    <td>You added</td>
                                    <td>Dec 30, 2023</td>
                                    <td>₹ 9,000</td>
                                    <td>-</td>
                                </tr>

                                <tr>
                                    <td>#96459756</td>
                                    <td>You added</td>
                                    <td>Dec 30, 2023</td>
                                    <td>₹ 14,000</td>
                                    <td>-</td>
                                </tr>

                            </tbody>
                        </table>
                    </div>

                    <div class="pagination-container">
                        <a href="#" class="page-link-custom page-arrow"><i class="fa-solid fa-arrow-left"></i></a>
                        <a href="#" class="page-link-custom active">01</a>
                        <a href="#" class="page-link-custom">02</a>
                        <a href="#" class="page-link-custom">03</a>
