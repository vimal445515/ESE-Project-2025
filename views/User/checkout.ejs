                            <label class="form-label">User name</label>
                            <input type="text" name="userName" id="userName" class="form-control" placeholder="First name">
                            <p id="userNameError" class="text-danger"></p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Company Name (Optional)</label>
                            <input type="text" name="companyName" id="companyName" class="form-control">
                           
                        </div>

                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <input type="text" name="address" id="address" class="form-control">
                             <p id="addressError" class="text-danger"></p>
                        </div>

                         <div class="col-md-3">
                            <label  class="form-label">PIN Code</label>
                            <input id="pinCode" name="pinCode" type="text" class="form-control">
                            <p class="text-danger" id="pinCodeError"></p>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Country</label>
                            <select id="country" name="country" class="form-select">
                                <option>Select...</option>
                                <option value="India" >India</option>
                            </select>
                             <p id="countryError" class="text-danger"></p>
                        </div>
                                            <%
                        const states = [
                        "Andhra Pradesh",
                        "Arunachal Pradesh",
                        "Assam",
                        "Bihar",
                        "Chhattisgarh",
                        "Goa",
                        "Gujarat",
                        "Haryana",
                        "Himachal Pradesh",
                        "Jharkhand",
                        "Karnataka",
                        "Kerala",
                        "Madhya Pradesh",
                        "Maharashtra",
                        "Manipur",
                        "Meghalaya",
                        "Mizoram",
                        "Nagaland",
                        "Odisha",
                        "Punjab",
                        "Rajasthan",
                        "Sikkim",
                        "Tamil Nadu",
                        "Telangana",
                        "Tripura",
                        "Uttar Pradesh",
                        "Uttarakhand",
                        "West Bengal"
                        ];
                        %>

                        <div class="col-md-3">
                        <label class="form-label">Region / State</label>

                        <select id="state" name="state" class="form-select">
                            <option value="" >
                            Select...
                            </option>

                            <% states.forEach(state => { %>
                            <option 
                                value="<%= state %>">
                                <%= state %>
                            </option>
                            <% }) %>
                        </select>
                         <p id="stateError" class="text-danger"></p>
                        </div>

                        <div class="col-md-3">
                            <label  class="form-label">City/district</label>
                            <input type="text" name="city" class="form-control" id="city" >
                          <p id="cityError" class="text-danger"></p>
                        </div>
                       

                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input id="email" name="email" type="email" class="form-control">
                             <p id="emailError" class="text-danger"></p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone Number</label>
                            <input id="phoneNumber" name="phoneNumber" type="text" class="form-control">
                         <p id="phoneNumberError" class="text-danger"></p>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="form-check">
                                
                                <input class="form-check-input" type="checkbox" id="defaultAddress">
                                <label class="form-check-label text-muted" for="defaultAddress">
                                    Ship into default address
                                </label>
                               
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Address</label>
                            <select id="address" class="form-select">
                                <option selected>Select...</option>
                                <%if(!type){%>
                                <% allAddress.forEach(address=>{%>
                                <option value="<%= address._id%>"><%= address.address%></option>
                                 <%})%>
                                 <%}%>
                            </select>
                        </div>
                    </div>

                    <hr class="my-5">

                    <h5 class="fw-bold mb-4">Payment Option</h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="payment-method">
                                <i class="bi bi-cash-stack"></i>
                                <p class="mb-3 small fw-bold">Cash on Delivery</p>
                                <input type="radio" value="cod" name="payment" id="cod">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="payment-method">
                                <i class="bi bi-lightning-fill"></i>
                                <p class="mb-3 small fw-bold">Razorpay</p>
                                <input type="radio" value="razorpay" name="payment" id="razorpay">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="payment-method">
                                <i class="bi bi-wallet2"></i>
                                <p class="mb-3 small fw-bold">My Wallet</p>
                                <input type="radio" value="wallet" name="payment" id="wallet">
                            </div>
                        </div>
                    </div>
              
            </div>
        </div>
        
        <input type="hidden" name="variantId" value="<%= variantId%>">
        <input type="hidden" name="productId" value="<%= productId%>">
        <input type="hidden" name="categoryId" value="<%= categoryId%>">


        <div class="col-lg-4">
            <div class="card shadow-sm p-4 summary-card">
                <h5 class="fw-bold mb-4">Order Summery</h5>
                 <%if(!type){%>
                <% products.forEach(product=>{%>
                <div class="product-item d-flex align-items-center mb-3">
                    <img src="<%= product.product.generalPhoto.url%>" class="me-3">
                    <div class="flex-grow-1">
                      <input type="hidden" name="quantity" value="<%=product.quantity%>">
                        <p class="mb-0 small fw-bold"><%= product.product.productName%></p>
                        <p class="mb-0 text-muted small"><%=product.quantity%> x <span class="price-text">₹<%= product.product.variants.price%>...</span></p>
                    </div>
                </div>
                <%})%>
                <%}%>

                <div class="summary-details small">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Sub-total</span>
                        <span id="subTotal" class="fw-bold">₹<%= orderDetails?.totalPriceCartItem%></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success fw-bold">Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Discount</span>
                        <span id="discount" class="fw-bold">₹<%=orderDetails?.totalDiscountPrice%></span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-muted">Tax</span>
                        <span id="tax" class="fw-bold">₹<%= orderDetails?.tax%></span>
                    </div>
                    <div id="couponDiscount"></div>
                </div>

                <div class="total-row d-flex justify-content-between align-items-center mb-4">
                    <span class="h6 fw-bold mb-0">Total</span>
                    <span id="total" class="h5 fw-bold mb-0">₹<%= orderDetails?.total%></span>
                </div>
                <button type="button" id="placeOrderButton" class="btn btn-primary w-100 btn-place-order">PLACE ORDER</button>
            </div>

             <!-- coupon apply -->
          <div class="card coupon-card shadow-sm ">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Coupon Code</h5>
                    <div class="mb-3">
                        <input type="text" id="couponInput" class="form-control p-3" placeholder="Coupon code">
                        <p id="couponInputError" class="text-danger"></p>
                    </div>
                    <button type="button" onclick="applayCoupon()" class="btn btn-apply px-4 py-2">APPLY COUPON</button>
                </div>
            </div>

            <div class="card coupon-card-applied shadow-sm d-none ">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Coupon Applied</h5>
                    <div class="mb-3">
                        <h5 id="appiledCoupon" class=" rounded-pill text-light p-3" style="background-color: #73e873;"></h5>
                        <input type="hidden" name="appliedCoupon" id="couponHolder">
                    </div>
                    <button type="button" onclick="removerCoupon()" class="btn btn-apply px-4 py-2">Remove</button>
                </div>
            </div>
            <!-- view all coupons -->

            <!-- View Coupons Button -->
            <button type="button"
            class="btn btn-outline-success w-100 mt-2"
            data-bs-toggle="modal"
            data-bs-target="#couponModal">
            View Available Coupons
            </button>

     
            <div
            class="modal fade "
            id="couponModal"
            tabindex="-1"
            aria-hidden="true">

            <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content">

              
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">
                    Available Coupons
                    </h5>
                    <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal">
                    </button>
                </div>

              
                <div class="modal-body overflow-auto" style="max-height:400px;">
                    <div class="row g-3 ">

                 <% coupons.forEach(coupon=>{%>
                    <div class="col-md-6 col-lg-4">
                        <div class="card border-success h-100">
                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold text-success mb-0">
                                <%= coupon.couponCode%>
                            </h6>
                            <span class="badge bg-dark">
                                <%=coupon.discount%>% OFF
                            </span>
                            </div>

                            <p class="small text-muted mt-2 mb-1">
                            Minimum order ₹<%= coupon.minimumOrder%>
                            </p>

                            <p class="small text-muted mb-2">
                            Expires on <%=coupon.expiryDate.toISOString().slice(0,10)%>
                            </p>

                            <button type="button" data-bs-dismiss="modal"  onclick="applayCoupon('<%= coupon.couponCode%>')"   class="btn btn-success mt-auto w-100">
                            Apply Coupon
                            </button>

                        </div>
                        </div>
                    </div>
                    <%})%>

                    </div>
                </div>
                </div>
            </div>
            </div>
 <!-- view all coupon End -->
        </div>
 
    </div>
</form>



<%- include("../partials/footer.ejs")%>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>

  
  const button= document.querySelector("#placeOrderButton");

  button.addEventListener("click", async function () {
 

    // Inputs
    const userName = userNameInput();
    const address = addressInput();
    const pinCode = pinCodeInput();
    const country = document.getElementById("country").value;
    const state = document.getElementById("state").value;
    const city = document.getElementById("city").value.trim();
    const email = document.getElementById("email").value.trim();
    const phone = document.getElementById("phoneNumber").value.trim();
    const payment = document.querySelector('input[name="payment"]:checked');

    clearErrors();

    let isValid = true;
     if(email===""){
         setError("emailError", "Email Required");
      isValid = false;
    }
     if(phone===""){
        setError("phoneNumberError", "Enter valid 10-digit phone number");
      isValid = false;
    }
    // Email
    if (!/^\S+@\S+\.\S+$/.test(email)) {
      setError("emailError", "Enter valid email");
      isValid = false;
    }

   

    // Phone
    if (!/^[6-9][0-9]{9}$/.test(phone)) {
      setError("phoneNumberError", "Enter valid 10-digit phone number");
      isValid = false;
    }


    // Username
    if (!userName) {
      setError("userNameError", "User name is required");
      isValid = false;
    }

    // Address
    if (!address) {
      setError("addressError", "Address is required");
      isValid = false;
    }

    // Pincode
    if (!/^[0-9]{6}$/.test(pinCode)) {
      setError("pinCodeError", "Enter valid 6-digit pincode");
      isValid = false;
    }

    // Country
    if (!country || country === "Select...") {
      setError("countryError", "Please select country");
      isValid = false;
    }

    // State
    if (!state) {
      setError("stateError", "Please select state");
      isValid = false;
    }

    // City
    if (!city) {
      setError("cityError", "City is required");
      isValid = false;
    }
     if(email===""){
         setError("emailError", "Email Required");
      isValid = false;
    }
     if(phone===""){
        setError("phoneNumberError", "Enter valid 10-digit phone number");
      isValid = false;
    }
    // Email
    if (!/^\S+@\S+\.\S+$/.test(email)) {
      setError("emailError", "Enter valid email");
      isValid = false;
    }

   

    // Phone
    if (!/^[6-9][0-9]{9}$/.test(phone)) {
      setError("phoneNumberError", "Enter valid 10-digit phone number");
      isValid = false;
    }
       const isCorrect = await validatePincodeMapping(
      pinCode,
      state,
      country,
      city
    );


        if (!isCorrect) {
        isValid = false;
       setError("pinCodeError", "State / Country / City does not match PIN code");
       setError("stateError", "Invalid state for this PIN code");
       setError("countryError", "Invalid country for this PIN code");
        setError("cityError", "Invalid city for this PIN code");
    }


    // Payment
    if (!payment) {
      alert("Please select a payment method");
      isValid = false;
    }
   

    // Final submit
    if (isValid) {
        const appliedCoupon = document.getElementById('couponHolder').value
        const variantId = '<%= variantId%>'
        const productId = "<%= productId%>"
        const categoryId = "<%= categoryId%>"
        const quantity = "<%=products[0].quantity%>"
        const data = JSON.stringify({
            appliedCoupon,
            variantId,
            productId,
            categoryId,
            userName,
            address,pinCode,
            country,
            state,city,
            email,
            phone,
            payment:payment.value,
            quantity
        })
      fetch('/orders/',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:data
      })
      .then(data=>data.json())
      .then(data=>{
        
        if(data.type === 'razorpay'){
            
            payNow(data.orderId)
            return 
         }
         if(data.type === 'walletError'){
            showToast(data.message,'error',)
         } 
        if(data.type ==="error"){
            window.location.href = data.href;
        }
        else if(data.type === "success"){
            
             window.location.href = data.href;
        }
      })
    }
  });

  // Helpers
  function setError(id, message) {
    document.getElementById(id).textContent = message;
  }

  function clearErrors() {
    document.querySelectorAll(".text-danger").forEach(e => e.textContent = "");
  }

  function userNameInput() {
    return document.getElementById("userName").value.trim();
  }

  function addressInput() {
    return document.getElementById("address").value.trim();
  }

  function pinCodeInput() {
    return document.getElementById("pinCode").value.trim();
  }



  async function payNow(orderId){
    const res = await fetch("/createOrder", { 
        method: "POST",
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({orderId})
    }
    );
    const order = await res.json();
   
    let options = {
    key:order.keyId,
    amount: order.amount,
    currency: "INR",
    order_id: order.orderId,
    name: "SES",
    handler: function (response) {
      fetch('/varifyPayment',{
        method:'POST',
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify(response)
      }).then(data=>data.json())
      .then(data=>{
        if(data.type === "success"){
            window.location.href=data.href;
        }
        if(data.type === "error"){
            window.location.href=data.href
        }
      })
    },
    modal:{
        ondismiss:function (){
           fetch('/paymentFaild',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({orderId:order.orderId})
           }).then(data=>data.json())
           .then(data=>{
            window.location.href = data.href
           })
        }
    }
  };

  let rzp1 = new Razorpay(options);
  rzp1.open();

  rzp1.on('payment.failed',function (response){
   
    fetch('/paymentFaild',{
        method:"POST",
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({orderId:response.error.metadata.order_id,reson:response.error.reason})
    }).then(data=>data.json())
    .then(data=>{
        if(data.type === "error"){
            window.location.href=data.href;
        }
    })
  })
  }







    const userName = document.getElementById("userName")
    const companyName =document.getElementById("companyName")
    const address = document.getElementById("address")
    const country = document.getElementById("country")
    const state  = document.getElementById("state")
    const city = document.getElementById("city")
    const pinCode = document.getElementById("pinCode")
    const email = document.getElementById("email")
    const phoneNumber  = document.getElementById("phoneNumber")



    document.getElementById("defaultAddress").addEventListener('click',()=>{
      
        fetch('/checkout/address',{
            method:"POST",
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({addressId:"<%= defaultAddressId %>"})
        }).then(data=>data.json())
                .then(data=>{
                    console.log(data)
                    userName.value = data.userName 
                    companyName.value = data.companyName
                   address.value  = data.address
                   city.value = data.city
                   email.value = data.email
                   phoneNumber.value = data.phoneNumber
                   pinCode.value = data.pinCode
                   state.value = data.state
                    country.value = data.country
                   
                })

        })

    document.querySelectorAll('#address').forEach(element=>{
        element.addEventListener('change',(e)=>{
            
                    fetch('/checkout/address',{
                    method:"POST",
                    headers:{'Content-Type':'application/json'},
                    body:JSON.stringify({addressId:e.target.value})
                }).then(data=>data.json())
                .then(data=>{
                    console.log(data)
                    userName.value = data.userName 
                    companyName.value = data.companyName
                    address.value  = data.address
                    city.value = data.city
                    email.value = data.email
                    phoneNumber.value = data.phoneNumber
                    pinCode.value = data.pinCode
                    state.value = data.state
                    country.value = data.country
                   
                })

        })
    })

   pinCode.addEventListener('input',(e)=>{
      if(e.target.value.length ===6){
        fetch(`https://api.postalpincode.in/pincode/${e.target.value}`)
        .then(data=>data.json())
        .then(data=>{
            if(data[0].Status==="Error"){
                document.getElementById("pinCodeError").textContent = "Pin code not found!"
            }
            if(data[0].Status==="Success"){
                document.getElementById("pinCodeError").textContent = ""
                state.value = data[0].PostOffice[0].State
                country.value = data[0].PostOffice[0].Country
                city.value = data[0].PostOffice[0].District
            }
     })
      }

   })


async function validatePincodeMapping(pinCode, state, country, city) {
  try {
    const res = await fetch(`https://api.postalpincode.in/pincode/${pinCode}`);
    const data = await res.json();

    if (data[0].Status !== "Success") return false;

    const postOffice = data[0].PostOffice[0];

    return (
      postOffice.State === state &&
      postOffice.Country === country &&
      postOffice.District === city
    );
  } catch (err) {
    console.error("Pincode validation error", err);
    return false;
  }
}

const subTotal = document.getElementById('subTotal')
const discount = document.getElementById('discount');
const tax = document.getElementById('tax');
const total = document.getElementById('total');

function applayCoupon(couponCode=couponInput.value.trim()){
    
    let couponInput = document.getElementById('couponInput')
    let inputError = document.getElementById('couponInputError')
    
    inputError.innerText = ''
    if(!couponCode){
        inputError.innerText="Enter a coupon code";
        return
    }
     
    const data = JSON.stringify({
         couponCode:couponCode,
         variantId : '<%= variantId%>',
         productId : "<%= productId%>",
         categoryId : "<%= categoryId%>",
         quantity : "<%=products[0].quantity%>"
    })
    fetch('/checkout/coupon',
        {
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:data
        }
    ).then(data=>data.json())
    .then(data=>{
        if(data.type==="success"){
            subTotal.innerText =`₹${ parseInt(data.totalPriceCartItem).toLocaleString('en-IN')}`
             discount.innerText = `₹${parseInt(data.totalDiscountPrice).toLocaleString('en-IN')}`
             tax.innerText = `₹${parseInt(data.tax).toLocaleString('en-IN')}`
             total.innerText =`₹${parseInt( data.total).toLocaleString('en-IN')}` 
             document.getElementById("couponDiscount").innerHTML=`<p class="text-success fw-semibold">
            You saved ₹<span>${parseInt(data.couponDiscount)}</span> on this order
            </p>`
            document.querySelector("#appiledCoupon").innerText = data.couponCode
            document.getElementById('couponHolder').value = data.couponCode
            document.querySelector('.coupon-card').style.display = 'none';
            document.getElementById('couponInput').value= ''
            document.querySelector('.coupon-card-applied').classList.remove('d-none')
            showToast('Coupon added successfully')
            
        }


        if(data.type==="error"){
           return showToast(data.message,'error')
        }
       
    })
}


function removerCoupon(){
     let couponInput = document.getElementById('couponInput')
     couponInput.innerText = ''
     
  const data = JSON.stringify({
         variantId : '<%= variantId%>',
         productId : "<%= productId%>",
         categoryId : "<%= categoryId%>",
         quantity : "<%=products[0].quantity%>"
    })

     fetch('/checkout/removeCoupon',
        {
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:data
        }
    ).then(data=>data.json())
    .then(data=>{
        
            console.log(data)
             subTotal.innerText =`₹${ parseInt(data.totalPriceCartItem).toLocaleString('en-IN')}`
             discount.innerText = `₹${parseInt(data.totalDiscountPrice).toLocaleString('en-IN')}`
             tax.innerText = `₹${parseInt(data.tax).toLocaleString('en-IN')}`
             total.innerText =`₹${parseInt( data.total).toLocaleString('en-IN')}` 
            document.getElementById("couponDiscount").innerHTML=``
           
            document.querySelector('.coupon-card').style.display = 'block';
            document.querySelector('.coupon-card-applied').classList.add('d-none')
             showToast('Coupon removed')
  
   
    })
}






