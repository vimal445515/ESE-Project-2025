<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SVG-Based Navbar Recreation</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* CSS Variables based on SVG colors */
        :root {
            --primary-blue: #4a6fdc; /* Main blue color */
            --text-grey: #8B8E99; /* Text/Icon color in the SVG */
            --text-dark: #1D1F2C; /* Text/Icon color for the user name */
            --green-avatar: #22CAAD; /* Green user circle */
            --blue-badge: #3858D6; /* Blue cart badge */
        }

        /* Base Navbar container styles matching the SVG rect/filter */
        .svg-navbar-recreation {
            background-color: white;
            /* Matches the SVG shadow effect (filter0_d_2593_8792) */
            box-shadow: 2px 4px 12px 0 rgba(0, 0, 0, 0.25); 
            padding: 10px 0;
        }

        /* Layout Container */
        .svg-navbar-recreation .container-fluid {
            max-width: 1300px; /* Adjusted for wider feel */
            padding: 0 40px; 
            margin: 0 auto;
        }

        /* --- 1. Left Side: Logo Area --- */
        .logo-area {
            display: flex;
            align-items: center;
            text-decoration: none;
            gap: 10px;
        }
        .logo-icon {
            font-size: 1.5rem;
            color: var(--text-grey);
            /* The SVG icon is complex, using a simple arrow to represent the shape */
        }
        .logo-text {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-grey);
            font-family: sans-serif; /* For a sharp, clean look */
        }
        
        /* --- 2. Center: Navigation Links --- */
        .nav-links {
            display: flex;
            gap: 40px; 
            /* Push the links far from the logo, centering them visually on the page */
            margin-left:80px; 
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-grey);
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--text-dark);
        }

        /* --- 3. Right Side: Utility Icons --- */
        .utility-icons {
            display: flex;
            align-items: center;
            gap: 20px; 
        }

        .icon-btn {
            position: relative;
            color: var(--text-grey);
            font-size: 1.25rem;
            text-decoration: none;
        }

        /* Customizing the cart icon to match the specific SVG element */
        .cart-icon .fa-cart-shopping {
            color: var(--text-grey);
        }

        .cart-badge {
            position: absolute;
            top: -10px;
            right: -10px;
            background-color: var(--blue-badge); 
            color: white;
            font-size: 0.7rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .user-profile {
            display: flex;
            align-items: center;
            text-decoration: none;
            gap: 8px;
            margin-left: 15px;
        }

        /* Simulating the SVG user circle with a Font Awesome icon */
        .user-avatar {
            font-size: 1.9rem;
            color: var(--green-avatar); 
        }

        .user-name {
            font-weight: 500;
            color: var(--text-dark);
            font-size: 0.95rem;
        }
    </style>
</head>
<body>

    <nav class="svg-navbar-recreation">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            
            <a class="logo-area" href="#">
                <svg width="74" height="36" viewBox="0 0 74 36" fill="none" xmlns="http://www.w3.org/2000/svg">
