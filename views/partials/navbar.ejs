                <rect width="40" height="36" fill="#F5F5F7"/>
                <path d="M21.5385 36V25.2H0L5.37988e-07 10.8H21.5385V0H24.6154L40 18L24.6154 36H21.5385Z" fill="#8B8E99"/>
                </svg>

            </a>

            <div class="nav-links">
                <a href="/home">Home</a>
                <a href="#">Contact</a>
                <a href="#">About</a>
                <a href="/products">Products</a>
            </div>
          <%  if(userName){ %>
            <div class="utility-icons">
                <a href="#" class="icon-btn"><i class="fa-regular fa-heart"></i></a>
                
                <a href="#" class="icon-btn cart-icon">
                    <i class="fa-solid fa-cart-shopping"></i>
                </a>
                
                <a href="#" class="user-profile">
                    <i class="fa-solid fa-circle-user user-avatar"></i>
                    <span class="user-name"><%= userName %></span>
                </a>
                <a href="/logout" class="btn btn-light">logout</a>
            </div>
            <% } else{ %>
            <div class="utility-icons">
                <a href="/login" class="icon-btn"><i class=""></i>login</a>
                
                
                <a href="/signup" class="icon-btn"><i class=""></i>sginUp</a>
            </div>
            <% } %>
        </div>
    </nav>

  
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>