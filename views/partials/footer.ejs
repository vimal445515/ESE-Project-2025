 <script>
       console.log( document.getElementById('emailError'))
        const reqForm = document.querySelector("#requestForm");
        reqForm.addEventListener('submit',(e)=>{
            e.preventDefault()
             let valid = true;
              
            if(reqForm.email.value === ""){
               
                document.getElementById('reqEmailError').innerText="email required"
                valid = false;
            }
           if(  !reqForm.email.value.includes("@") || !reqForm.email.value.includes('.')){
                 document.getElementById('reqEmailError').innerText="email required"
                 valid = false;
            }
           if(!reqForm.name.value || typeof reqForm.name.value != 'string' ){
                document.getElementById('reqNameError').innerText="invalid name"
                valid =  false
            }
            if(!reqForm.phoneNumber.value  || reqForm.phoneNumber.value.toString().length !== 10 ){
                document.getElementById('reqPhoneNumberError').innerText = "invalid"
                valid = false
            }

            if(valid){

         
            const formData = {
                email:reqForm.email.value,
                name:reqForm.name.value,
                subject:`Contact request`,
                message:`Constomer contact number: ${reqForm.phoneNumber.value}`
            }

            fetch('/contact',{
                method:"POST",
                headers:{"Content-Type":"application/json"},
                body:JSON.stringify(formData)
            })
            .then(data=>data.json())
            .then(data=>{
                if(data.type== "success"){
                    
                    reqForm.email.value = ""
                    reqForm.name.value =  ""
                    reqForm.phoneNumber.value = ""
                    showToast("Request send successfully")
                }else if( data.type =="error"){
                   
                    showToast(data.message,'error')
                }
            }).catch((error)=>{
                console.log(error)
                showToast("somthing was wrong we can't send data",'error');
            })
               }
        })
    </script>
