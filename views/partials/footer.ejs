<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exact Converted Footer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Poppins:wght@500;700&display=swap" rel="stylesheet">

    <style>
        /* ------------------ FOOTER CONTAINER & BACKGROUND ------------------ */
        .app-footer {
            /* Full 1440px width is simulated by using container-fluid and centered content */
            /* Reversing the rotated gradient: #0B0B0B at top, #383638 at bottom */
            background: linear-gradient(to bottom, #0B0B0B 33.08%, #383638 97.94%);
            padding-top: 64px;
            padding-bottom: 64px;
            color: #FFFFFF;
            font-family: 'Inter', sans-serif;
        }

        /* ------------------ COLORS & TYPOGRAPHY ------------------ */
        .text-accent-blue { color: #3858D6 !important; }
        .bg-accent-blue { background-color: #3858D6 !important; }
        .text-color-light-40 { color: rgba(255, 255, 255, 0.4) !important; }
        .text-color-placeholder { color: #8B8E99 !important; }

        /* Custom Font Weights/Sizes */
        .fw-700 { font-weight: 700; }
        .fw-500 { font-weight: 500; }

        /* ------------------ LEFT COLUMN: FEEDBACK CARD ------------------ */
        .feedback-card {
            background: #17181C;
            border-radius: 16px;
            width: 392px; /* Fixed width as per design */
            height: 523px; /* Fixed height as per design */
            padding: 32px 24px;
            position: relative; /* For absolute positioning of privacy text */
        }
        .feedback-card .intro {
            gap: 20px !important;
        }
        .feedback-card .feedback-label {
            font-weight: 700;
            font-size: 10px;
            line-height: 140%;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }
        .feedback-card h2 {
            font-weight: 700;
            font-size: 28px;
            line-height: 130%; /* 36px */
            letter-spacing: -0.02em;
        }

        /* Input Styling */
        .form-label-custom {
            color: #8B8E99;
            font-weight: 500;
            font-size: 14px;
            line-height: 20px;
        }
        .input-group-custom .form-control {
            box-sizing: border-box;
            height: 44px;
            border: 1px solid #E4E7E9;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 16px;
            line-height: 24px;
            color: #8B8E99;
            background-color: #FFFFFF; /* Ensure white background for input */
            filter: drop-shadow(0px 1px 2px rgba(16, 24, 40, 0.05));
        }
        .input-group-custom .input-group-text {
            background-color: #FFFFFF;
            border: 1px solid #E4E7E9;
            border-right: none;
            border-radius: 8px 0 0 8px;
            height: 44px;
        }
        .input-group-custom .form-control:focus {
             border-color: #3858D6;
             box-shadow: 0 0 0 0.25rem rgba(56, 88, 214, 0.25);
        }
        .feedback-card .btn {
            width: 151px;
            height: 44px;
            border-radius: 10px;
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 14px;
            line-height: 125.5%; /* 18px */
        }
        .feedback-card .privacy-text {
            position: absolute;
            bottom: 24px;
            left: 24px;
            right: 24px;
            font-weight: 700;
            font-size: 10px;
            line-height: 140%;
            opacity: 0.4;
        }

        /* ------------------ RIGHT COLUMN: LINKS & CONTACT ------------------ */
        .main-content {
             /* Offset by 628px left from 1440 container, simulating the right alignment */
             padding-left: 64px;
        }
        
        .main-content .logo-bar {
            margin-top: -18px; /* Offset to align with feedback card top elements */
        }
        .main-content .logo-text {
            font-family: 'Poppins', sans-serif;
            font-weight: 500;
            font-size: 16px;
            line-height: 24px;
            color: #8B8E99;
        }
        .main-content .section-header {
            font-weight: 700;
            font-size: 10px;
            line-height: 140%;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            margin-bottom: 24px;
        }
        .main-content .link-item {
            font-weight: 700;
            font-size: 14px;
            line-height: 140%;
            text-decoration: none;
            color: #FFFFFF;
            display: block;
            margin-bottom: 5px;
        }
        .main-content .link-item:hover {
            color: #3858D6;
        }
        .main-content .contact-info p {
            font-weight: 700;
            font-size: 14px;
            line-height: 140%;
            margin-bottom: 5px;
        }

        /* Bottom Bar */
        .footer-bottom-bar {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 24px;
            margin-top: 48px;
        }
        .social-icon-box {
            width: 50px;
            height: 50px;
            border: 1px solid rgba(255, 255, 255, 0.125);
            border-radius: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #FFFFFF;
        }
        .social-icon-box:hover {
            background-color: rgba(56, 88, 214, 0.5);
            border-color: #3858D6;
        }
        .copyright-text {
            font-weight: 700;
            font-size: 10px;
            line-height: 140%;
            opacity: 0.4;
        }

        /* Ensure fixed width elements stack on smaller screens */
        @media (max-width: 991.98px) {
            .feedback-card {
                width: 100%;
                height: auto;
                margin-bottom: 48px;
            }
            .main-content {
                padding-left: 12px;
            }
        }
    </style>
</head>
